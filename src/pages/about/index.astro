---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandIcon from '../../components/BrandIcon.astro';
import '../../styles/about.css';
import { getThemeSettings, type SiteSocialIconKey } from '../../lib/theme-settings';
const { settings } = getThemeSettings();
const resolvedSocialItems = settings.site.socialLinks.resolvedSocialItems.filter((item) => item.visible);
const aboutTitle = settings.page.about.title || '关于';
const aboutSubtitle = settings.page.about.subtitle;

type SocialActionItem = {
  key: string;
  href: string;
  label: string;
  title: string;
  icon: SiteSocialIconKey;
};

type ContactItem = {
  key: string;
  href: string;
  icon: SiteSocialIconKey;
  text: string;
};

const formatExternalLabel = (href: string): string => {
  try {
    const parsed = new URL(href);
    const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
    return path || parsed.hostname;
  } catch {
    return href;
  }
};

const socialItems: SocialActionItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    label: item.label,
    title: item.label,
    icon: item.iconKey
  }))
];

const contactItems: ContactItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    icon: item.iconKey,
    text: item.displayText || (item.id === 'email' ? item.href.replace(/^mailto:/i, '') : formatExternalLabel(item.href))
  }))
];
---

<BaseLayout title={aboutTitle} bodyClass="about-page">
  <div class="page-header page-header--about">
    <div class="page-heading">
      <h1 class="page-title">{aboutTitle}</h1>
      {aboutSubtitle ? <span class="page-subtitle">{aboutSubtitle}</span> : null}
    </div>
    {
      socialItems.length ? (
        <div class="page-actions">
          {socialItems.map((item) => (
            <a class="icon-link" href={item.href} aria-label={item.title} title={item.title}>
              <BrandIcon name={item.icon} class="icon" />
            </a>
          ))}
        </div>
      ) : null
    }
  </div>
  <p class="about-intro-line">
    WZVico' Blog 基于 Astro 主题 <a href="https://github.com/cxro/astro-whono">Whono</a> 搭建。<br>
    利用 Codex 进行编辑修改，满足个人记录、分享、管理、发布、部署的需求。<br>
  </p>
  <h2 class="section-title about-section-title">栏目指引</h2>
  <div class="site-guide">
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">长文</h3>
        <span class="site-guide-link">/longform/</span>
      </div>
      <p class="site-guide-desc">长篇原创、翻译、系列文章。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">絮语</h3>
        <span class="site-guide-link">/bits/</span>
      </div>
      <p class="site-guide-desc">记录零散的想法、片段、即时感。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">拾选</h3>
        <span class="site-guide-link">/picks/</span>
      </div>
      <p class="site-guide-desc">分享书单、影视、音乐等。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">归档</h3>
        <span class="site-guide-link">/archive/</span>
      </div>
      <p class="site-guide-desc">按年份分组的归档目录。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">资料</h3>
        <span class="site-guide-link">/Materials/</span>
      </div>
      <p class="site-guide-desc">视频与文件资料索引。</p>
    </article>
  </div>

  <h2 class="section-title about-section-title">技术栈</h2>
  <div class="tech-stack">
    <section class="tech-group">
      <div class="tech-group-title">构建与渲染</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Astro / Vite</span>
          </div>
          <div class="tech-item-desc">内容站点与构建</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">CSS / 排版</span>
          </div>
          <div class="tech-item-desc">排版与阅读体验</div>
        </li>
      </ul>
    </section>
    <section class="tech-group">
      <div class="tech-group-title">语言与工具</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">TypeScript</span>
          </div>
          <div class="tech-item-desc">类型约束与脚本支持</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Markdown</span>
          </div>
          <div class="tech-item-desc">内容写作与发布流程</div>
        </li>
      </ul>
    </section>
    
  </div>

  <h2 class="section-title about-section-title">常见问题</h2>
  <section class="qa-list" aria-label="常见问题">
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>为什么我部署后会看到 SITE_URL is not set 警告？</summary>
      <p class="qa-answer">因为没配置生产域名。未设置时会用占位域名，<code>canonical</code>/<code>og:url</code>/<code>sitemap</code>/<code>robots</code> 会不完整。部署平台里环境变量中添加 <code>SITE_URL=https://你的域名</code>，重新构建即可。</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>为什么有的文章没出现在归档里？</summary>
      <p class="qa-answer">归档会过滤掉 <code>archive: false</code> 的文章。它们仍然是“已发布可访问”的，但不会出现在归档列表与归档 RSS 中（用于少数不想被目录收录的内容）。</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>为什么我在 /longform/ 点开文章会跳到 /archive/.../？</summary>
      <p class="qa-answer">项目把文章详情统一在 <code>/archive/{'{'}slug{'}'}/</code>，<code>/longform/</code> 主要作为文章流列表入口，这样可以避免重复详情路由，便于长期维护。</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>如何反馈问题或参与改进？</summary>
      <p class="qa-answer">直接在仓库创建 <a href="https://github.com/cxro/astro-whono/issues">Issue</a>，或提交 <a href="https://github.com/cxro/astro-whono/pulls">Pull Request</a>。</p>
    </details>
  </section>

  {
    contactItems.length ? (
      <>
        <h2 class="section-title about-section-title">联系与订阅</h2>
        <section class="contact-block" aria-label="联系方式">
          <p class="contact-note">如果你有问题、建议，或想订阅更新，可以通过以下方式联系。</p>
          <ul class="contact-list">
            {contactItems.map((item) => (
              <li>
                <span class="contact-link-head" aria-hidden="true">
                  <BrandIcon name={item.icon} class="contact-icon" />
                </span>
                <a href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : null
  }

</BaseLayout>
