---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandIcon from '../../components/BrandIcon.astro';
import '../../styles/about.css';
import { getAboutContent } from '../../lib/about-content';
import { getThemeSettings, type SiteSocialIconKey } from '../../lib/theme-settings';
const { settings } = getThemeSettings();
const aboutContent = getAboutContent();
const resolvedSocialItems = settings.site.socialLinks.resolvedSocialItems.filter((item) => item.visible);
const aboutTitle = settings.page.about.title || '关于';
const aboutSubtitle = settings.page.about.subtitle;

type SocialActionItem = {
  key: string;
  href: string;
  label: string;
  title: string;
  icon: SiteSocialIconKey;
};

type ContactItem = {
  key: string;
  href: string;
  icon: SiteSocialIconKey;
  text: string;
};

const formatExternalLabel = (href: string): string => {
  try {
    const parsed = new URL(href);
    const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
    return path || parsed.hostname;
  } catch {
    return href;
  }
};

const socialItems: SocialActionItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    label: item.label,
    title: item.label,
    icon: item.iconKey
  }))
];

const contactItems: ContactItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    icon: item.iconKey,
    text: item.displayText || (item.id === 'email' ? item.href.replace(/^mailto:/i, '') : formatExternalLabel(item.href))
  }))
];

type IntroLinePart = {
  text: string;
  href?: string;
};

const parseIntroLineLinks = (line: string): IntroLinePart[] => {
  const parts: IntroLinePart[] = [];
  const linkPattern = /\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g;
  let cursor = 0;
  let match: RegExpExecArray | null;

  while ((match = linkPattern.exec(line)) !== null) {
    if (match.index > cursor) {
      parts.push({ text: line.slice(cursor, match.index) });
    }

    const text = match[1] ?? '';
    const href = match[2];

    if (href) {
      parts.push({ text, href });
    }
    cursor = match.index + match[0].length;
  }

  if (cursor < line.length) {
    parts.push({ text: line.slice(cursor) });
  }

  return parts.length ? parts : [{ text: line }];
};
---

<BaseLayout title={aboutTitle} bodyClass="about-page">
  <div class="page-header page-header--about">
    <div class="page-heading">
      <h1 class="page-title">{aboutTitle}</h1>
      {aboutSubtitle ? <span class="page-subtitle">{aboutSubtitle}</span> : null}
    </div>
    {
      socialItems.length ? (
        <div class="page-actions">
          {socialItems.map((item) => (
            <a class="icon-link" href={item.href} aria-label={item.title} title={item.title}>
              <BrandIcon name={item.icon} class="icon" />
            </a>
          ))}
        </div>
      ) : null
    }
  </div>
  <p class="about-intro-line">
    {aboutContent.introLines.map((line) => (
      <>
        {parseIntroLineLinks(line).map((part) =>
          part.href ? <a href={part.href} target="_blank" rel="noreferrer">{part.text}</a> : <>{part.text}</>
        )}
        <br />
      </>
    ))}
  </p>
  <h2 class="section-title about-section-title">{aboutContent.guide.title}</h2>
  <div class="site-guide">
    {aboutContent.guide.items.map((item) => (
      <article class="site-guide-item">
        <div class="site-guide-head">
          <h3 class="site-guide-title">{item.title}</h3>
          <span class="site-guide-link">{item.href}</span>
        </div>
        <p class="site-guide-desc">{item.description}</p>
      </article>
    ))}
  </div>

  <h2 class="section-title about-section-title">{aboutContent.tech.title}</h2>
  <div class="tech-stack">
    {aboutContent.tech.groups.map((group) => (
      <section class="tech-group">
        <div class="tech-group-title">{group.title}</div>
        <ul class="tech-list">
          {group.items.map((item) => (
            <li class="tech-item">
              <div class="tech-item-head">
                <span class="tech-item-title">{item.title}</span>
              </div>
              <div class="tech-item-desc">{item.description}</div>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>

  <h2 class="section-title about-section-title">{aboutContent.faq.title}</h2>
  <section class="qa-list" aria-label={aboutContent.faq.title}>
    {aboutContent.faq.items.map((item) => (
      <details class="qa-item">
        <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>{item.question}</summary>
        <p class="qa-answer">{item.answer}</p>
      </details>
    ))}
  </section>

  {
    contactItems.length ? (
      <>
        <h2 class="section-title about-section-title">{aboutContent.contact.title}</h2>
        <section class="contact-block" aria-label="联系方式">
          <p class="contact-note">{aboutContent.contact.note}</p>
          <ul class="contact-list">
            {contactItems.map((item) => (
              <li>
                <span class="contact-link-head" aria-hidden="true">
                  <BrandIcon name={item.icon} class="contact-icon" />
                </span>
                <a href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : null
  }

</BaseLayout>
