---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminReadonlyNotice from '../../../components/admin/AdminReadonlyNotice.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import AuthorLibraryManager from '../../../components/admin/AuthorLibraryManager.astro';
import LongformDraftEditor from '../../../components/admin/LongformDraftEditor.astro';
import BitsDraftDialog from '../../../components/BitsDraftDialog.astro';
import {
  ADMIN_AUTHOR_LIBRARY_RELATIVE_PATH,
  readAdminAuthorProfiles
} from '../../../lib/admin-console/authors';
import { getAdminContentOverviewData } from '../../../lib/admin-console/content';
import { getAboutContent } from '../../../lib/about-content';
import { readAdminPicksIntro, readAdminPicksStats } from '../../../lib/admin-console/picks';
import { getMaterials } from '../../../lib/materials';
import { createWithBase } from '../../../utils/format';

type AdminCategoryTabId = 'longform' | 'bits' | 'picks' | 'materials' | 'about' | 'author';

type AdminCategoryTab = {
  id: AdminCategoryTabId;
  label: string;
  description: string;
  publicHref: string;
  sourceLabel: string;
};

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const [{ default: adminShellStylesHref }, { default: adminCategoryStylesHref }] = await Promise.all([
  import('../../../styles/components/admin-shell.css?url'),
  import('../../../styles/components/admin-category.css?url')
]);

const tabs = [
  {
    id: 'longform',
    label: '长文',
    description: '管理文章型内容分类，适合沉淀完整主题、教程、译文或长篇记录。',
    publicHref: '/longform/',
    sourceLabel: 'src/content/longform'
  },
  {
    id: 'bits',
    label: '絮语',
    description: '管理短记录与轻量更新分类，适合快速想法、片段笔记与日常状态。',
    publicHref: '/bits/',
    sourceLabel: 'src/content/bits'
  },
  {
    id: 'picks',
    label: '拾选',
    description: '管理精选内容分类，适合链接、摘录、推荐与阶段性收藏。',
    publicHref: '/picks/',
    sourceLabel: 'src/content/picks'
  },
  {
    id: 'materials',
    label: '资料',
    description: '管理资料页分类入口，适合公开展示资料索引、清单或项目材料。',
    publicHref: '/Materials/',
    sourceLabel: 'src/content/materials'
  },
  {
    id: 'about',
    label: '关于',
    description: '管理关于页分类入口，适合维护个人介绍、站点说明与联系信息。',
    publicHref: '/about/',
    sourceLabel: 'src/pages/about'
  },
  {
    id: 'author',
    label: '作者',
    description: '管理文章作者资料库，新增或删除作者，并维护可用于长文作者与译者选择的名称和可选头像。',
    publicHref: '/longform/',
    sourceLabel: ADMIN_AUTHOR_LIBRARY_RELATIVE_PATH
  }
] as const satisfies readonly AdminCategoryTab[];

const isAdminCategoryTabId = (value: string): value is AdminCategoryTabId =>
  tabs.some((tab) => tab.id === value);

const selectedTabParam = Astro.url.searchParams.get('tab')?.trim() ?? '';
const selectedTabId: AdminCategoryTabId = isAdminCategoryTabId(selectedTabParam)
  ? selectedTabParam
  : 'longform';
const selectedTab = tabs.find((tab) => tab.id === selectedTabId) ?? tabs[0];
const contentOverview = isDev ? await getAdminContentOverviewData() : null;
const contentSummary = contentOverview?.summaries.find((summary) => summary.key === selectedTabId);
const picksStats = selectedTabId === 'picks' ? await readAdminPicksStats() : null;
const picksIntro = selectedTabId === 'picks' ? await readAdminPicksIntro() : [];
const materialItems = selectedTabId === 'materials' ? await getMaterials() : [];
const aboutContent = selectedTabId === 'about' ? getAboutContent() : null;
const authorProfiles = selectedTabId === 'author' ? await readAdminAuthorProfiles() : [];
const latestMaterialDate = materialItems
  .map((item) => item.dateValue)
  .sort((left, right) => right.localeCompare(left))[0] ?? '未设置日期';
const shouldShowLongformCreateConsole = isDev && selectedTabId === 'longform';
const shouldShowBitsDraftConsole = isDev && selectedTabId === 'bits';
const shouldShowPicksCreateConsole = isDev && selectedTabId === 'picks';
const shouldShowMaterialsCreateConsole = isDev && selectedTabId === 'materials';
const shouldShowAboutContentConsole = isDev && selectedTabId === 'about' && aboutContent !== null;
const shouldShowAuthorConsole = isDev && selectedTabId === 'author';
const longformCreateEndpoint = withBase('/api/admin/category/longform/');
const bitsDraftCreateEndpoint = withBase('/api/admin/category/bits/');
const picksCreateEndpoint = withBase('/api/admin/category/picks/');
const materialsCreateEndpoint = withBase('/api/admin/category/materials/');
const aboutContentEndpoint = withBase('/api/admin/category/about/');
const authorLibraryEndpoint = withBase('/api/admin/category/authors/');
const bitsDraftStylesHref = shouldShowBitsDraftConsole
  ? (await import('../../../styles/components/bits.css?url')).default
  : null;
const adminStylesHref = [
  adminShellStylesHref,
  adminCategoryStylesHref,
  bitsDraftStylesHref
].filter((href): href is string => typeof href === 'string' && href.length > 0);

const buildCategoryHref = (tabId: AdminCategoryTabId): string =>
  tabId === 'longform'
    ? withBase('/admin/category/')
    : withBase(`/admin/category/?tab=${tabId}`);

const selectedStats = shouldShowAuthorConsole
  ? [
      { label: '当前作者', value: `${authorProfiles.length} 位` },
      { label: '已有头像', value: `${authorProfiles.filter((author) => author.avatar.trim()).length} 位` },
      { label: '保存位置', value: ADMIN_AUTHOR_LIBRARY_RELATIVE_PATH }
    ]
  : shouldShowAboutContentConsole && aboutContent
  ? [
      { label: '栏目指引', value: `${aboutContent.guide.items.length} 项` },
      { label: '常见问题', value: `${aboutContent.faq.items.length} 条` },
      { label: '保存位置', value: 'src/data/about.json' }
    ]
  : shouldShowMaterialsCreateConsole
  ? [
      { label: '当前资料', value: `${materialItems.length} 项` },
      { label: '最近创建', value: latestMaterialDate },
      { label: '保存位置', value: selectedTab.sourceLabel }
    ]
  : shouldShowPicksCreateConsole && picksStats
  ? [
      { label: '当前拾选', value: `${picksStats.itemCount} 条` },
      { label: '最新拾选', value: picksStats.latestPickDateLabel },
      { label: '保存位置', value: picksStats.storagePathLabel }
    ]
  : contentSummary
  ? [
      { label: '当前条目', value: `${contentSummary.totalCount} 项` },
      { label: '草稿数量', value: `${contentSummary.draftCount} 项` },
      { label: '最近更新', value: contentSummary.latestDateLabel }
    ]
  : [
      { label: '公开入口', value: selectedTab.publicHref },
      { label: '维护来源', value: selectedTab.sourceLabel },
      { label: '状态', value: isDev ? '分类入口已建立' : '只读预览' }
    ];
---

<AdminLayout title="Category Console" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="category"
    title="Category Console"
    subtitle="分类管理"
    showNav={isDev}
  >
    {
      isDev ? (
        <section class="admin-category-console" aria-labelledby="admin-category-title">
          <nav class="admin-category-tabs" aria-label="分类页面切换">
            {
              tabs.map((tab) => {
                const isActive = tab.id === selectedTabId;
                return (
                  <a
                    class:list={['admin-category-tab', isActive && 'is-active']}
                    href={buildCategoryHref(tab.id)}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {tab.label}
                  </a>
                );
              })
            }
          </nav>

          <section class="admin-category-panel" aria-labelledby="admin-category-title">
            <div class="admin-category-panel__head">
              <p class="admin-overview-card__eyebrow">Category</p>
              <h2 id="admin-category-title" class="admin-category-panel__title">{selectedTab.label}</h2>
              <p class="admin-category-panel__body">{selectedTab.description}</p>
            </div>

            <div class="admin-category-panel__grid" aria-label={`${selectedTab.label} 分类信息`}>
              {
                selectedStats.map((item) => (
                  <article class="admin-category-panel__card">
                    <p class="admin-category-panel__card-label">{item.label}</p>
                    <p class="admin-category-panel__card-value">{item.value}</p>
                  </article>
                ))
              }
            </div>

            {
              shouldShowAuthorConsole ? (
                <div class="admin-overview-card__actions">
                  <a class="admin-btn admin-btn--secondary" href={buildCategoryHref('longform')}>用于新增长文</a>
                  <a class="admin-btn admin-btn--ghost" href={withBase('/admin/images/')}>管理头像图片</a>
                </div>
              ) : (
                <div class="admin-overview-card__actions">
                  <a class="admin-btn admin-btn--secondary" href={withBase(selectedTab.publicHref)}>查看公开页</a>
                  <a class="admin-btn admin-btn--ghost" href={withBase('/admin/content/')}>打开 Content Console</a>
                </div>
              )
            }

            {
              shouldShowLongformCreateConsole ? (
                <LongformDraftEditor createEndpoint={longformCreateEndpoint} />
              ) : null
            }

            {
              shouldShowBitsDraftConsole ? (
                <BitsDraftDialog inline createEndpoint={bitsDraftCreateEndpoint} />
              ) : null
            }

            {
              shouldShowPicksCreateConsole ? (
                <>
                  <section
                    class="admin-category-picks-create"
                    aria-labelledby="admin-category-picks-intro-title"
                    data-picks-intro-root
                    data-picks-intro-endpoint={picksCreateEndpoint}
                  >
                    <div class="admin-category-picks-create__head">
                      <div>
                        <p class="admin-overview-card__eyebrow">Picks Intro</p>
                        <h3 id="admin-category-picks-intro-title" class="admin-category-picks-create__title">
                          页面介绍
                        </h3>
                      </div>
                    </div>

                    <form class="admin-category-picks-create__form" data-picks-intro-form>
                      <article class="admin-category-picks-create__row">
                        <label class="admin-category-picks-create__field admin-category-picks-create__field--full">
                          <span>/picks/ 下方介绍</span>
                          <textarea class="admin-field__control" data-picks-intro-field rows="4" placeholder="每行显示为一段介绍">{picksIntro.join('\n')}</textarea>
                          <small class="admin-category-picks-create__help">每一行会在 /picks/ 页面介绍区显示为一行。</small>
                        </label>
                      </article>

                      <div class="admin-category-picks-create__footer">
                        <div class="admin-category-picks-create__actions">
                          <button class="admin-btn admin-btn--primary" type="submit" data-picks-intro-submit>保存介绍</button>
                        </div>
                        <p class="admin-category-picks-create__status" data-picks-intro-status role="status" aria-live="polite"></p>
                      </div>
                    </form>
                  </section>

                  <section
                    class="admin-category-picks-create"
                    aria-labelledby="admin-category-picks-title"
                    data-picks-create-root
                    data-picks-create-endpoint={picksCreateEndpoint}
                  >
                    <div class="admin-category-picks-create__head">
                      <div>
                        <p class="admin-overview-card__eyebrow">Picks</p>
                        <h3 id="admin-category-picks-title" class="admin-category-picks-create__title">
                          新增拾选
                        </h3>
                      </div>
                    </div>

                    <form class="admin-category-picks-create__form" data-picks-create-form>
                      <article class="admin-category-picks-create__row">
                        <label class="admin-category-picks-create__field admin-category-picks-create__field--title">
                          <span>作品名 *</span>
                          <input class="admin-field__control" data-pick-field="title" type="text" autocomplete="off" placeholder="《置身事内》" />
                        </label>
                        <label class="admin-category-picks-create__field admin-category-picks-create__field--creator">
                          <span>作者 / 创作者</span>
                          <input class="admin-field__control" data-pick-field="authors" type="text" autocomplete="off" placeholder="兰小欢、合作者" />
                          <small class="admin-category-picks-create__help">多作者用顿号、逗号或分号分隔。</small>
                        </label>
                        <label class="admin-category-picks-create__field admin-category-picks-create__field--reason">
                          <span>推荐理由 *</span>
                          <textarea class="admin-field__control" data-pick-field="reason" rows="4" placeholder="它解决了什么问题，带来什么视角，适合谁在什么时候翻开。"></textarea>
                        </label>
                        <label class="admin-category-picks-create__field admin-category-picks-create__field--tags">
                          <span>标签</span>
                          <input class="admin-field__control" data-pick-field="tags" type="text" autocomplete="off" placeholder="agent, Vibe coding" />
                          <small class="admin-category-picks-create__help">带空格的标签用逗号隔开；可以不写 #，系统会自动处理。</small>
                        </label>
                      </article>

                      <div class="admin-category-picks-create__footer">
                        <div class="admin-category-picks-create__actions">
                          <button class="admin-btn admin-btn--primary" type="submit" data-picks-create-submit>写入拾选</button>
                        </div>
                        <p class="admin-category-picks-create__status" data-picks-create-status role="status" aria-live="polite"></p>
                      </div>
                    </form>
                  </section>
                </>
              ) : null
            }

            {
              shouldShowMaterialsCreateConsole ? (
                <section
                  class="admin-category-materials-create"
                  aria-labelledby="admin-category-materials-title"
                  data-materials-create-root
                  data-materials-create-endpoint={materialsCreateEndpoint}
                >
                  <div class="admin-category-materials-create__head">
                    <div>
                      <p class="admin-overview-card__eyebrow">Materials</p>
                      <h3 id="admin-category-materials-title" class="admin-category-materials-create__title">
                        新增资料
                      </h3>
                    </div>
                  </div>

                  <form class="admin-category-materials-create__form" data-materials-create-form>
                    <article class="admin-category-materials-create__row">
                      <label class="admin-category-materials-create__field admin-category-materials-create__field--title">
                        <span>标题 *</span>
                        <input class="admin-field__control" data-material-field="title" type="text" autocomplete="off" placeholder="资料标题" />
                      </label>
                      <label class="admin-category-materials-create__field admin-category-materials-create__field--href">
                        <span>链接 *</span>
                        <input class="admin-field__control" data-material-field="href" type="text" inputmode="url" autocomplete="off" placeholder="example.com/material" />
                      </label>
                      <label class="admin-category-materials-create__field admin-category-materials-create__field--label">
                        <span>类型</span>
                        <input class="admin-field__control" data-material-field="label" type="text" autocomplete="off" placeholder="视频 / PDF" />
                      </label>
                      <label class="admin-category-materials-create__field admin-category-materials-create__field--description">
                        <span>描述</span>
                        <textarea class="admin-field__control" data-material-field="description" rows="3" placeholder="前台列表说明"></textarea>
                      </label>
                    </article>

                    <div class="admin-category-materials-create__footer">
                      <div class="admin-category-materials-create__actions">
                        <button class="admin-btn admin-btn--primary" type="submit" data-materials-create-submit>创建资料</button>
                      </div>
                      <p class="admin-category-materials-create__status" data-materials-create-status role="status" aria-live="polite"></p>
                    </div>
                  </form>
                </section>
              ) : null
            }

            {
              shouldShowAboutContentConsole && aboutContent ? (
                <section
                  class="admin-category-about"
                  aria-labelledby="admin-category-about-title"
                  data-about-content-root
                  data-about-content-endpoint={aboutContentEndpoint}
                >
                  <div class="admin-category-about__head">
                    <div>
                      <p class="admin-overview-card__eyebrow">About Copy</p>
                      <h3 id="admin-category-about-title" class="admin-category-about__title">
                        页面文案
                      </h3>
                    </div>
                    <p class="admin-category-about__hint">
                      页头标题、副标题和社交链接仍在 <code>/admin/theme/</code> 设置。
                    </p>
                  </div>

                  <form class="admin-category-about__form" data-about-content-form>
                    <article class="admin-category-about__block">
                      <div class="admin-category-about__block-head">
                        <h4 class="admin-category-about__block-title">开头介绍</h4>
                      </div>
                      <label class="admin-category-about__field admin-category-about__field--full">
                        <span>介绍文字</span>
                        <textarea class="admin-field__control" data-about-field="introLines" data-about-required rows="3">{aboutContent.introLines.join('\n')}</textarea>
                        <small class="admin-category-about__help">每一行会在 About 页面显示为一行。</small>
                      </label>
                    </article>

                    <article class="admin-category-about__block">
                      <div class="admin-category-about__block-head">
                        <label class="admin-category-about__field admin-category-about__field--section-title">
                          <span>栏目指引大标题</span>
                          <input class="admin-field__control" data-about-field="guide.title" data-about-required type="text" value={aboutContent.guide.title} />
                        </label>
                      </div>
                      <div class="admin-category-about__rows">
                        {aboutContent.guide.items.map((item, index) => (
                          <article class="admin-category-about__row" data-about-guide-index={String(index)}>
                            <label class="admin-category-about__field admin-category-about__field--title">
                              <span>栏目名</span>
                              <input class="admin-field__control" data-about-guide-field="title" data-about-required type="text" value={item.title} />
                            </label>
                            <label class="admin-category-about__field admin-category-about__field--path">
                              <span>路径文字</span>
                              <input class="admin-field__control" data-about-guide-field="href" data-about-required type="text" value={item.href} />
                            </label>
                            <label class="admin-category-about__field admin-category-about__field--description">
                              <span>说明</span>
                              <textarea class="admin-field__control" data-about-guide-field="description" data-about-required rows="1">{item.description}</textarea>
                            </label>
                          </article>
                        ))}
                      </div>
                    </article>

                    <article class="admin-category-about__block">
                      <div class="admin-category-about__block-head">
                        <label class="admin-category-about__field admin-category-about__field--section-title">
                          <span>项目大标题</span>
                          <input class="admin-field__control" data-about-field="tech.title" data-about-required type="text" value={aboutContent.tech.title} />
                        </label>
                      </div>
                      <div class="admin-category-about__rows">
                        {aboutContent.tech.groups.map((group, groupIndex) => (
                          <article class="admin-category-about__group" data-about-tech-group-index={String(groupIndex)}>
                            <label class="admin-category-about__field admin-category-about__field--full">
                              <span>分组标题</span>
                              <input class="admin-field__control" data-about-tech-group-field="title" data-about-required type="text" value={group.title} />
                            </label>
                            {group.items.map((item, itemIndex) => (
                              <article class="admin-category-about__row" data-about-tech-item-index={String(itemIndex)}>
                                <label class="admin-category-about__field admin-category-about__field--title">
                                  <span>项目名</span>
                                  <input class="admin-field__control" data-about-tech-field="title" data-about-required type="text" value={item.title} />
                                </label>
                                <label class="admin-category-about__field admin-category-about__field--description">
                                  <span>说明</span>
                                  <textarea class="admin-field__control" data-about-tech-field="description" data-about-required rows="1">{item.description}</textarea>
                                </label>
                              </article>
                            ))}
                          </article>
                        ))}
                      </div>
                    </article>

                    <article class="admin-category-about__block">
                      <div class="admin-category-about__block-head">
                        <label class="admin-category-about__field admin-category-about__field--section-title">
                          <span>常见问题大标题</span>
                          <input class="admin-field__control" data-about-field="faq.title" data-about-required type="text" value={aboutContent.faq.title} />
                        </label>
                        <button class="admin-btn admin-btn--secondary" type="button" data-about-faq-add>添加问答</button>
                      </div>
                      <div class="admin-category-about__rows" data-about-faq-list>
                        {aboutContent.faq.items.map((item, index) => (
                          <article class="admin-category-about__row admin-category-about__row--faq" data-about-faq-index={String(index)}>
                            <label class="admin-category-about__field admin-category-about__field--title">
                              <span>问题</span>
                              <input class="admin-field__control" data-about-faq-field="question" data-about-required type="text" value={item.question} />
                            </label>
                            <label class="admin-category-about__field admin-category-about__field--full">
                              <span>回答</span>
                              <textarea class="admin-field__control" data-about-faq-field="answer" data-about-required rows="3">{item.answer}</textarea>
                            </label>
                            <button class="admin-btn admin-btn--ghost admin-category-about__remove" type="button" data-about-faq-remove>删除</button>
                          </article>
                        ))}
                      </div>
                      <template data-about-faq-template>
                        <article class="admin-category-about__row admin-category-about__row--faq" data-about-faq-index="">
                          <label class="admin-category-about__field admin-category-about__field--title">
                            <span>问题</span>
                            <input class="admin-field__control" data-about-faq-field="question" data-about-required type="text" value="" />
                          </label>
                          <label class="admin-category-about__field admin-category-about__field--full">
                            <span>回答</span>
                            <textarea class="admin-field__control" data-about-faq-field="answer" data-about-required rows="3"></textarea>
                          </label>
                          <button class="admin-btn admin-btn--ghost admin-category-about__remove" type="button" data-about-faq-remove>删除</button>
                        </article>
                      </template>
                    </article>

                    <article class="admin-category-about__block">
                      <div class="admin-category-about__block-head">
                        <h4 class="admin-category-about__block-title">联系与订阅</h4>
                      </div>
                      <div class="admin-category-about__row">
                        <label class="admin-category-about__field admin-category-about__field--title">
                          <span>联系区大标题</span>
                          <input class="admin-field__control" data-about-field="contact.title" data-about-required type="text" value={aboutContent.contact.title} />
                        </label>
                        <label class="admin-category-about__field admin-category-about__field--description">
                          <span>联系区说明</span>
                          <textarea class="admin-field__control" data-about-field="contact.note" data-about-required rows="3">{aboutContent.contact.note}</textarea>
                        </label>
                      </div>
                    </article>

                    <div class="admin-category-about__footer">
                      <div class="admin-category-about__actions">
                        <button class="admin-btn admin-btn--primary" type="submit" data-about-content-submit>保存 About 文案</button>
                      </div>
                      <p class="admin-category-about__status" data-about-content-status role="status" aria-live="polite"></p>
                    </div>
                  </form>
                </section>
              ) : null
            }

            {
              shouldShowAuthorConsole ? (
                <AuthorLibraryManager
                  authors={authorProfiles}
                  endpoint={authorLibraryEndpoint}
                  sourceLabel={ADMIN_AUTHOR_LIBRARY_RELATIVE_PATH}
                />
              ) : null
            }
          </section>
        </section>
      ) : (
        <AdminReadonlyNotice>
