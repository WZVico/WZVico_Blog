---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroImage from '../components/HeroImage.astro';
import EntryListItem from '../components/EntryListItem.astro';
import '../styles/home.css';
import {
  ADMIN_HOME_INTRO_LINK_DEFAULT,
  getAdminHomeIntroLinkOption
} from '../lib/admin-console/theme-shared';
import { getLongformDerivedText, getLongformSlug, getVisibleLongforms } from '../lib/content';
import {
  getLongformHomeIndexArticleMetaSettings,
  getLongformHomeIndexDisplayDate,
  orderByLongformHomeIndexDisplayDate
} from '../lib/home-index';
import { getLongformArticlePeople } from '../lib/longform-people';
import { getThemeSettings, getVisibleArticleMetaTags } from '../lib/theme-settings';
import { createWithBase } from '../utils/format';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { settings } = getThemeSettings();
const {
  home: { introLead, introMore, introMoreLinks, showIntroLead, showIntroMore, heroPresetId, heroImageSrc, heroImageAlt },
  ui: { articleMeta }
} = settings;
const shouldShowHero = heroPresetId !== 'none';
const shouldShowIntro = showIntroLead || showIntroMore;
const homeBodyClass = [
  'home',
  !shouldShowHero ? 'home--no-hero' : null,
  !shouldShowIntro ? 'home--no-intro' : null,
  !shouldShowHero && !shouldShowIntro ? 'home--compact-start' : null
]
  .filter(Boolean)
  .join(' ');
const resolvedIntroMoreLinks = (introMoreLinks.length ? introMoreLinks : [...ADMIN_HOME_INTRO_LINK_DEFAULT]).map(
  (linkKey) => getAdminHomeIntroLinkOption(linkKey)
);

const latest = (await getVisibleLongforms()).sort(orderByLongformHomeIndexDisplayDate).slice(0, 11);

type HomeHeadCriticalFontFace = {
  family: 'LXGW WenKai Lite' | 'Noto Serif SC';
  fileName: string;
  weight: 400 | 600;
  unicodeRange: string;
};

// Keep this subset aligned with the faces the home shell actually uses above the fold.
const HOME_HEAD_CRITICAL_FONT_FACES = [
  {
    family: 'LXGW WenKai Lite',
    fileName: 'lxgw-wenkai-lite-latin.woff2',
    weight: 400,
    unicodeRange: 'U+0000-00FF, U+2000-206F, U+3000-303F, U+FF00-FFEF'
  },
  {
    family: 'LXGW WenKai Lite',
    fileName: 'lxgw-wenkai-lite-cjk-common.woff2',
    weight: 400,
    unicodeRange: 'U+4E00-9FFF'
  },
  {
    family: 'Noto Serif SC',
    fileName: 'noto-serif-sc-400-latin.woff2',
    weight: 400,
    unicodeRange: 'U+0000-00FF, U+2000-206F, U+3000-303F, U+FF00-FFEF'
  },
  {
    family: 'Noto Serif SC',
    fileName: 'noto-serif-sc-400-cjk-common.woff2',
    weight: 400,
    unicodeRange: 'U+4E00-9FFF'
  },
  {
    family: 'Noto Serif SC',
    fileName: 'noto-serif-sc-600-latin.woff2',
    weight: 600,
    unicodeRange: 'U+0000-00FF, U+2000-206F, U+3000-303F, U+FF00-FFEF'
  },
  {
    family: 'Noto Serif SC',
    fileName: 'noto-serif-sc-600-cjk-common.woff2',
    weight: 600,
    unicodeRange: 'U+4E00-9FFF'
  }
] as const satisfies readonly HomeHeadCriticalFontFace[];

const renderHomeHeadCriticalFontFace = ({
  family,
  fileName,
  weight,
  unicodeRange
}: HomeHeadCriticalFontFace): string => String.raw`@font-face {
  font-family: "${family}";
  src: url("${withBase(`/fonts/${fileName}`)}") format("woff2");
  font-weight: ${weight};
  font-style: normal;
  font-display: swap;
  unicode-range: ${unicodeRange};
}`;

const homeHeadCriticalCss = [
  HOME_HEAD_CRITICAL_FONT_FACES.map(renderHomeHeadCriticalFontFace).join('\n\n'),
  String.raw`

:root {
  color-scheme: light;
  --bg: #fffefc;
  --text: #292524;
  --muted: #57534e;
  --faint: #a8a29e;
  --border: #e7e5e4;
  --accent: #b91c1c;
  --code-header-bg: #f2f2f0;
  --code-content-bg: #fcfcfb;
  --panel: var(--code-header-bg);
  --max: 900px;
  --sidebar: 320px;
  --tap-min-h: 44px;
  --pad-x: 48px;
  --card-hover-outset: 14px;
  --card-pad: 12px var(--card-hover-outset);
}

:root[data-theme="dark"] {
  color-scheme: dark;
  --bg: #1a1a1a;
  --text: #e5e5e5;
  --muted: #a3a3a3;
  --faint: #737373;
  --border: #333333;
  --accent: #f87171;
  --code-header-bg: #2a2a2a;
  --code-content-bg: #222222;
  --panel: var(--code-header-bg);
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--text);
  font-family: "Noto Serif SC", ui-serif, Georgia, "Times New Roman", "Songti SC", serif;
  line-height: 1.75;
  font-size: 16px;
}

img {
  max-width: 100%;
  height: auto;
}

html {
  scrollbar-gutter: stable;
}

@supports not (scrollbar-gutter: stable) {
  html {
    overflow-y: scroll;
  }
}

a {
  color: var(--text);
  text-decoration: none;
  border-bottom: 1px solid transparent;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.skip-link {
  position: absolute;
  left: -999px;
  top: 8px;
  background: var(--bg);
  color: var(--text);
  border: 1px solid var(--border);
  padding: 6px 10px;
  border-radius: 6px;
  z-index: 10;
}

.skip-link:focus {
  left: 8px;
}

.shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: var(--sidebar) 1px 1fr;
  max-width: 1100px;
  margin: 0 auto;
}

.divider {
  background: var(--border);
  margin: 50px 0;
}

.sidebar {
  padding: 55px 24px;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 24px;
  position: sticky;
  top: 0;
  height: 100vh;
}

.sidebar__title {
  font-family: Georgia, serif;
  font-size: 28px;
  letter-spacing: 0.5px;
}

.sidebar__quote {
  max-width: 220px;
  text-align: right;
  font-family: Georgia, serif;
  font-style: italic;
  font-size: 16px;
  color: var(--muted);
}

.nav {
  list-style: none;
  padding: 0;
  margin: 12px 0 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.nav a {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  padding: 2px 0;
  font-size: 16px;
}

.nav a[aria-current="page"] {
  text-decoration: underline;
  text-underline-offset: 5px;
}

.nav .dot {
  width: 4px;
  height: 4px;
  border-radius: 999px;
  background: var(--text);
  opacity: 0.55;
}

.nav .nav-ornament {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  color: var(--text);
  opacity: 0.55;
  font-size: 14px;
  line-height: 1;
  font-family: "LXGW WenKai Lite", "Kaiti SC", "STKaiti", serif;
}

.sidebar-actions {
  margin-top: auto;
  display: inline-flex;
  gap: 10px;
  align-items: center;
  align-self: flex-end;
}

.icon-button {
  width: 34px;
  height: 34px;
  padding: 0;
  border: 0;
  border-radius: 999px;
  background: transparent;
  color: var(--muted);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-button .icon {
  width: 18px;
  height: 18px;
  display: block;
}

.theme-toggle .icon-moon,
.theme-toggle .icon-system {
  display: none;
}

:root[data-theme="dark"] .theme-toggle .icon-moon {
  display: block;
}

:root[data-theme="dark"] .theme-toggle .icon-sun {
  display: none;
}

:root[data-theme-mode="system"] .theme-toggle .icon-system {
  display: block;
}

:root[data-theme-mode="system"] .theme-toggle .icon-moon,
:root[data-theme-mode="system"] .theme-toggle .icon-sun {
  display: none;
}

.reader-toggle .icon-book-closed {
  display: none;
}

body[data-reading="immersive"] .reader-toggle .icon-book-closed {
  display: block;
}

body[data-reading="immersive"] .reader-toggle .icon-book-open {
  display: none;
}

.content {
  padding: 56px var(--pad-x);
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  min-width: 0;
  width: 100%;
}

.content__inner {
  max-width: var(--max);
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  width: 100%;
}

.intro {
  margin: 28px 0 32px;
  color: var(--text);
  font-size: 16px;
  letter-spacing: 0.02em;
}

.section-title {
  font-size: 20px;
  margin: 28px 0 2px;
  position: relative;
}

.section-title::after {
  content: "";
  display: block;
  width: 32px;
  height: 1px;
  background: var(--border);
  margin-top: 6px;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 16px;
}

.list-item {
  padding: 18px 0;
}

.list-item--link {
  display: block;
  color: inherit;
  text-decoration: none;
  border-radius: 14px;
  margin-inline: calc(var(--card-hover-outset, 14px) * -1);
  padding: var(--card-pad);
}

.list-item__row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16px;
}

.list-item__row .badge {
  height: 24px;
}

.badge {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  white-space: nowrap;
  padding: 0 7px;
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.6px;
  color: var(--muted);
  background: #fafafa;
  position: relative;
  top: 1px;
}

:root[data-theme="dark"] .badge {
  background: #1f1f1f;
  border-color: #3f3f3f;
  color: var(--muted);
}

.list-item__title {
  margin: 0;
  font-size: 18px;
  font-weight: 600;
}

.list-item__title-link {
  color: inherit;
  border-bottom: 1px solid transparent;
  text-decoration: none;
}

.list-item__title-link:hover,
.list-item__title-link:focus-visible {
  color: var(--accent);
  border-bottom-color: currentColor;
  outline: none;
}

/* Keep above-the-fold EntryListItem copy stable until the deferred global stylesheet arrives. */
.list-item__excerpt {
  margin: 10px 0 0;
  color: #666;
  font-size: 15px;
  line-height: 1.6;
  font-family: "LXGW WenKai Lite", "Kaiti SC", "STKaiti", serif;
}

.meta-line {
  margin-top: 10px;
  margin-bottom: 12px;
  font-size: 13px;
  color: var(--faint);
}

.meta-line--items {
  --meta-line-separator-gap: 1.45em;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  column-gap: var(--meta-line-separator-gap);
  row-gap: 6px;
}

.meta-line__item {
  position: relative;
  display: inline-flex;
  align-items: center;
  flex: 0 0 auto;
  max-width: 100%;
  min-width: 0;
}

.meta-line__item:not(.meta-line__item--tags):not(.meta-line__item--people):not(.meta-line__item--person) {
  white-space: nowrap;
}

.meta-line__item--tags {
  flex: 0 0 auto;
  flex-wrap: wrap;
  gap: 0.65em;
  max-width: 100%;
  min-width: 0;
  width: max-content;
  white-space: normal;
}

.meta-line__item--tags .tag {
  white-space: nowrap;
}

.meta-line__item--tags.is-line-start {
  flex-basis: 100%;
}

.meta-line__item--people,
.meta-line__item--person {
  --article-byline-label-gap: 10px;
  gap: var(--article-byline-label-gap);
  flex-wrap: wrap;
}

.meta-line__item + .meta-line__item::before {
  content: "·";
  position: absolute;
  inset-inline-start: calc(var(--meta-line-separator-gap) / -2);
  top: 50%;
  transform: translate(-50%, -50%);
  margin: 0;
  color: var(--faint);
  pointer-events: none;
}

.meta-line__item.is-line-start::before {
  content: none;
  margin: 0;
}

.list-item .meta-line {
  margin-top: 12px;
  margin-bottom: 8px;
  padding-top: 0;
}

.meta-line .tag {
  color: var(--accent);
}

.article-author-list,
.article-author,
.article-translator {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
}

.article-translator {
  gap: var(--article-byline-label-gap, 10px);
}

.article-author-list {
  gap: 10px;
}

.article-author + .article-author::before,
.article-translator::before {
  content: "·";
  color: var(--faint);
  margin-right: 2px;
}

.meta-line__item--people > .article-translator:first-child::before {
  content: none;
  margin-right: 0;
}

.article-author-avatar {
  width: 24px;
  height: 24px;
  flex: 0 0 auto;
  border: 1px solid var(--border);
  border-radius: 50%;
  background: var(--code-content-bg);
  color: var(--accent);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.article-author-avatar img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.article-byline__label {
  color: var(--faint);
}

.article-byline__name {
  color: var(--text);
}

.article-byline__name--link {
  border-bottom: 1px solid transparent;
  text-decoration: none;
}

.article-byline__name--link:hover,
.article-byline__name--link:focus-visible {
  color: var(--accent);
  border-bottom-color: currentColor;
  outline: none;
}

@media (min-width: 901px) {
  .nav li {
    display: flex;
    justify-content: flex-end;
  }

  .nav a {
    display: inline-flex;
    width: fit-content;
  }
}

@media (max-width: 900px) {
  /* Keep mobile shell rules aligned with src/styles/components/layout.css. */
  :root {
    color-scheme: light;
    --sidebar: 1fr;
    --tap-min-h: 44px;
    --pad-x: 20px;
    --card-hover-outset: 12px;
    --card-pad: 10px var(--card-hover-outset);
    --quote-pad: 0.85rem;
    --header-gap: 4px;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --bg: #1a1a1a;
    --text: #e5e5e5;
    --muted: #a3a3a3;
    --faint: #737373;
    --border: #333333;
    --accent: #f87171;
    --code-header-bg: #2a2a2a;
    --panel: var(--code-header-bg);
  }

  .shell {
    grid-template-columns: 1fr;
  }

  .divider {
    display: none;
  }

  .sidebar {
    position: static;
    height: auto;
    padding: calc(32px + env(safe-area-inset-top)) calc(var(--pad-x) + env(safe-area-inset-right))
      calc(16px + env(safe-area-inset-bottom)) calc(var(--pad-x) + env(safe-area-inset-left));
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    row-gap: 10px;
    column-gap: 12px;
  }

  .sidebar__title {
    transform-origin: left center;
    order: 1;
    flex: 1 1 auto;
    font-size: 24px;
  }

  .sidebar__quote {
    display: none;
  }

  .nav {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 12px;
    margin-top: 2px;
    order: 4;
    width: 100%;
  }

  .nav a {
    justify-content: center;
    padding: 6px 8px;
    min-height: var(--tap-min-h);
    border-radius: 999px;
    transform-origin: left center;
  }

  .nav a[aria-current="page"] {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }

  .nav .dot,
  .nav .nav-ornament {
    display: none;
  }

  .icon-button {
    min-width: var(--tap-min-h);
    min-height: var(--tap-min-h);
  }

  .sidebar-actions {
    order: 2;
    margin-top: 0;
    align-self: center;
  }

  .sidebar-actions .icon-button {
    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
  }

  .sidebar-actions .icon-button .icon {
    width: 18px;
    height: 18px;
  }

  .sidebar {
    padding-bottom: calc(16px + env(safe-area-inset-bottom));
  }

  .content {
    padding: calc(10px + env(safe-area-inset-top)) calc(var(--pad-x) + env(safe-area-inset-right))
      calc(48px + env(safe-area-inset-bottom)) calc(var(--pad-x) + env(safe-area-inset-left));
  }

  .list-item {
    padding: 16px 0;
  }
}

@media (min-width: 641px) and (max-width: 900px) {
  .sidebar {
    padding: calc(28px + env(safe-area-inset-top)) calc(var(--pad-x) + env(safe-area-inset-right))
      calc(36px + env(safe-area-inset-bottom)) calc(var(--pad-x) + env(safe-area-inset-left));
    padding-bottom: calc(20px + env(safe-area-inset-bottom));
  }

  .content {
    padding: calc(18px + env(safe-area-inset-top)) calc(var(--pad-x) + env(safe-area-inset-right))
      calc(56px + env(safe-area-inset-bottom)) calc(var(--pad-x) + env(safe-area-inset-left));
  }

  .nav a {
    padding: 8px 12px;
  }
}

@media (max-width: 640px) {
  .sidebar {
    padding: calc(18px + env(safe-area-inset-top)) calc(var(--pad-x) + env(safe-area-inset-right))
      calc(24px + env(safe-area-inset-bottom)) calc(var(--pad-x) + env(safe-area-inset-left));
    padding-bottom: calc(14px + env(safe-area-inset-bottom));
  }

  .nav {
    gap: 8px 10px;
  }

  .nav a {
    padding: 6px 8px;
    font-size: 15px;
  }

  .content {
    padding: calc(4px + env(safe-area-inset-top)) calc(var(--pad-x) + env(safe-area-inset-right))
      calc(36px + env(safe-area-inset-bottom)) calc(var(--pad-x) + env(safe-area-inset-left));
  }
}
`
].join('\n\n');
---

<BaseLayout bodyClass={homeBodyClass} deferGlobalStyles={true}>
  <style slot="head" is:inline set:html={homeHeadCriticalCss}></style>
  <h1 class="sr-only">Astro Themes by Whono</h1>
  {
    shouldShowHero && (
      <div class="hero">
        <HeroImage isLCP src={heroImageSrc} alt={heroImageAlt} />
      </div>
    )
  }

  {
    shouldShowIntro && (
      <div class="intro intro--serif">
        {showIntroLead && <span class="intro__lead">{introLead}</span>}
        {showIntroMore && (
          <span class="intro__more">
            {introMore}
            {resolvedIntroMoreLinks.map((link, index) => (
              <>
                {' '}
                {index > 0 && <>或{' '}</>}
                {index === resolvedIntroMoreLinks.length - 1 ? (
                  <span class="intro__link-tail">
                    <a href={withBase(link.href)}>{link.label}</a>
                    <span class="intro__tail-punct">。</span>
                  </span>
                ) : (
                  <a href={withBase(link.href)}>{link.label}</a>
                )}
              </>
            ))}
          </span>
        )}
      </div>
    )
  }

  <h2 class="section-title section-title--index">索引</h2>

  <div class="list">
    {latest.map((entry) => {
      const slug = getLongformSlug(entry);
      const href = withBase(`/archive/${slug}/`);
      const visibleTags = getVisibleArticleMetaTags(entry.data.tags, 'list');
      return (
        <EntryListItem
          href={href}
          title={entry.data.title}
          date={getLongformHomeIndexDisplayDate(entry)}
          visibleTags={visibleTags}
          badge={entry.data.badge}
          articlePeople={getLongformArticlePeople(entry, settings, withBase)}
          articleMetaSettings={getLongformHomeIndexArticleMetaSettings(entry, articleMeta)}
          excerpt={getLongformDerivedText(entry).excerpt}
        />
      );
    })}
  </div>
</BaseLayout>
