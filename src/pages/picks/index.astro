---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UiIcon from '../../components/UiIcon.astro';
import Lightbox from '../../components/Lightbox.astro';
import '../../styles/article.css';
import '../../styles/picks.css';
import { getEntry, render } from 'astro:content';
import { getThemeSettings } from '../../lib/theme-settings';

const prod = import.meta.env.PROD;
const DEFAULT_READS_TITLE = '拾选';
const DEFAULT_READS_SUBTITLE = '书单与简短理由。';

const entry = await getEntry('picks', 'index');
if (!entry) {
  throw new Error('Missing picks page entry: src/content/picks/index.md');
}
if (prod && entry.data.draft) {
  throw new Error('picks entry is marked draft...');
}

const {
  settings: {
    page
  }
} = getThemeSettings();
const { Content, headings } = await render(entry);
const readsTitle = page.picks.title ?? entry.data.title ?? DEFAULT_READS_TITLE;
const readsSubtitle = page.picks.subtitle ?? entry.data.subtitle ?? DEFAULT_READS_SUBTITLE;

// Build a grouped TOC: H2 as section titles, H3 as items.
type TocItem = { text: string; slug: string };
type TocGroup = { title: string; items: TocItem[] };

const groups: TocGroup[] = [];
let current: TocGroup | null = null;
for (const h of headings) {
  if (h.depth === 2) {
    current = { title: h.text, items: [] };
    groups.push(current);
  } else if (h.depth === 3) {
    if (!current) {
      current = { title: '目录', items: [] };
      groups.push(current);
    }
    current.items.push({ text: h.text, slug: h.slug });
  }
}
---

<BaseLayout
  title={readsTitle}
  description="分享值得一读的书单和简短理由。"
  bodyClass="picks-page immersive-page"
>
  <div class="page-header page-header--picks reader-exit-anchor">
    <div class="page-heading">
      <h1 class="page-title">{readsTitle}</h1>
      {readsSubtitle ? <span class="page-subtitle">{readsSubtitle}</span> : null}
    </div>
    <div class="picks-header-actions">
      <div class="picks-search-cluster">
        <form class="picks-search" role="search" data-picks-search-form>
          <label class="sr-only" for="picks-search">搜索拾选</label>
          <input
            id="picks-search"
            type="search"
            placeholder="搜索：关键词 / 标签"
            autocomplete="off"
            enterkeyhint="search"
            aria-controls="picks-search-results-panel"
          />
          <button class="picks-search-btn" type="submit">搜索</button>
        </form>
      </div>
    </div>
    <button
      id="reader-exit"
      class="icon-button reader-exit"
      type="button"
      aria-label="退出阅读"
      title="退出阅读"
      aria-hidden="true"
      tabindex="-1"
    >
      <UiIcon name="reader-exit" class="icon" />
    </button>
  </div>

  <div class="picks-search-status" id="picks-search-status"></div>
  <p class="sr-only" id="picks-search-live" role="status" aria-live="polite" aria-atomic="true"></p>

  <div data-picks-browse>
    <div class="intro">
      这里按年份收集我想留下、回看或推荐的书。
      <br />每一本只留下最直接的理由：它解决了什么问题，带来什么视角，适合谁在什么时候翻开。
      <br />书单会慢慢更新，不追求完整，只保留真正想分享的部分。
    </div>

    <nav class="picks-toc" aria-label="目录">
      {groups.map((g) => (
        <details open>
          <summary>{g.title}</summary>
          <ul class="toc-items">
            {g.items.map((it, i) => (
              <li>
                <a href={`#${it.slug}`}>
                  <span class="toc-num">{i + 1}</span>
                  <span>{it.text}</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </nav>

    <div class="picks-content prose" id="picks-content">
      <Content />
    </div>
  </div>

  <section
    id="picks-search-results-panel"
    class="bits-search-results picks-search-results"
    data-picks-search-results
    hidden
    aria-label="搜索结果"
  >
    <div class="bits-search-results__header">
      <p class="bits-search-results__summary" data-picks-search-results-summary role="status" aria-live="polite">
        搜索结果
      </p>
      <button class="bits-search-results__clear" type="button" data-picks-search-clear>重置筛选</button>
    </div>
    <div class="bits-search-results__list" data-picks-search-results-list></div>
  </section>

  <script is:inline>
    (() => {
      const mq = window.matchMedia('(max-width: 640px)');
      const sync = () => {
        if (mq.matches) {
          document.querySelectorAll('.picks-toc details[open]').forEach((el) => {
            el.removeAttribute('open');
          });
        } else {
          document.querySelectorAll('.picks-toc details:not([open])').forEach((el) => {
            el.setAttribute('open', '');
          });
        }
      };
      sync();
      mq.addEventListener('change', sync);

      const content = document.querySelector('.picks-content');
      if (content) {
        const nodes = content.querySelectorAll('h2, h3');
        let count = 0;
        nodes.forEach((node) => {
          if (node.tagName === 'H2') {
            count = 0;
            return;
          }
          if (node.tagName === 'H3') {
            count += 1;
            node.setAttribute('data-num', String(count));
          }
        });
      }
    })();
  </script>

  <Lightbox
    id="lightbox"
    label="图片预览"
    enableZoom={false}
    enablePan={false}
    enableSwipeDownClose={false}
  />

  <script>
    import { initArticleLightbox, initCodeCopyButtons } from '../../scripts/lightbox';
    import '../../scripts/picks-search';

    initCodeCopyButtons();
    initArticleLightbox({
      dialogId: 'lightbox',
      containerSelector: '.picks-content.prose',
      enableZoom: false,
      enablePan: false,
      enableSwipeDownClose: false
    });
  </script>
</BaseLayout>
