---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmptyState from '../../components/EmptyState.astro';
import UiIcon from '../../components/UiIcon.astro';
import Lightbox from '../../components/Lightbox.astro';
import '../../styles/article.css';
import '../../styles/picks.css';
import { getCollection, getEntry, render } from 'astro:content';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import { getThemeSettings } from '../../lib/theme-settings';
import { isPicksIndexEntryId } from '../../lib/content';

const prod = import.meta.env.PROD;
const DEFAULT_READS_TITLE = '拾选';
const DEFAULT_READS_SUBTITLE = '书单与简短理由。';
const DEFAULT_READS_INTRO = [
  '这里按年份收集我想留下、回看或推荐的书。',
  '每一本只留下最直接的理由：它解决了什么问题，带来什么视角，适合谁在什么时候翻开。',
  '书单会慢慢更新，不追求完整，只保留真正想分享的部分。'
];
const PLANNED_READS_TITLE = '待拾';

const entry = await getEntry('picks', 'index');
if (!entry) {
  throw new Error('Missing picks page entry: src/content/picks/index.md');
}
if (prod && entry.data.draft) {
  throw new Error('picks entry is marked draft...');
}

const {
  settings: {
    page
  }
} = getThemeSettings();
const readsTitle = page.picks.title ?? entry.data.title ?? DEFAULT_READS_TITLE;
const readsSubtitle = page.picks.subtitle ?? entry.data.subtitle ?? DEFAULT_READS_SUBTITLE;
const readsIntro = entry.data.intro?.length ? entry.data.intro : DEFAULT_READS_INTRO;

// Build a grouped TOC from one-file-per-pick entries. The index file only stores page metadata.
type TocItem = { text: string; slug: string };
type TocGroup = { title: string; items: TocItem[] };
type PickStatus = 'shared' | 'planned';
type PickFileItem = {
  id: string;
  title: string;
  tocText: string;
  authors: string[];
  tags: string[];
  status: PickStatus;
  identityKey: string;
  year: number;
  dateValue: number;
  Content: AstroComponentFactory;
};

const getPickFileTitle = (item: Pick<{ title: string; authors: string[] }, 'title' | 'authors'>) =>
  item.authors.length > 0 ? `${item.title}- ${item.authors.join('、')}` : item.title;
const getPickFileAnchorId = (id: string) =>
  `pick-${id.replace(/\.md$/i, '').replace(/[^a-zA-Z0-9\u4e00-\u9fa5]+/g, '-').replace(/^-+|-+$/g, '')}`;
const getPickFileYear = (id: string, year: number | undefined, date: Date | undefined) => {
  if (year) return year;
  if (date) return date.getFullYear();
  const pathYear = Number(id.match(/\b(20\d{2}|19\d{2})\b/)?.[1]);
  return Number.isFinite(pathYear) ? pathYear : 0;
};
const normalizePickIdentityPart = (value: string) =>
  value
    .normalize('NFKC')
    .replace(/[《》]/g, '')
    .replace(/\s+/g, '')
    .toLowerCase();
const getPickIdentityKey = (title: string, authors: string[]) =>
  `${normalizePickIdentityPart(title)}::${authors.map(normalizePickIdentityPart).join('|')}`;

const pickEntries = await getCollection('picks', ({ id, data }) =>
  !isPicksIndexEntryId(id) && (!prod || data.draft !== true)
);
const pickFileItems = await Promise.all(
  pickEntries.map(async (pickEntry) => {
    const rendered = await render(pickEntry);
    const year = getPickFileYear(pickEntry.id, pickEntry.data.year, pickEntry.data.date);
    const authors = pickEntry.data.authors ?? [];
    const title = getPickFileTitle({
      title: pickEntry.data.title,
      authors
    });

    return {
      id: getPickFileAnchorId(pickEntry.id),
      title,
      tocText: pickEntry.data.title,
      authors,
      tags: pickEntry.data.tags ?? [],
      status: pickEntry.data.status,
      identityKey: getPickIdentityKey(pickEntry.data.title, authors),
      year,
      dateValue: pickEntry.data.date?.valueOf() ?? 0,
      Content: rendered.Content
    } satisfies PickFileItem;
  })
);
const sharedPickFileItems = pickFileItems.filter((item) => item.status !== 'planned');
const sharedPickIdentityKeys = new Set(sharedPickFileItems.map((item) => item.identityKey));
const plannedPickFileItems = pickFileItems
  .filter((item) => item.status === 'planned' && !sharedPickIdentityKeys.has(item.identityKey))
  .sort((left, right) => right.dateValue - left.dateValue || left.title.localeCompare(right.title));
const pickFileGroups = Array.from(
  sharedPickFileItems
    .sort((left, right) => right.dateValue - left.dateValue || left.title.localeCompare(right.title))
    .reduce((map, item) => {
      const key = item.year || new Date(item.dateValue).getFullYear();
      const list = map.get(key) ?? [];
      list.push(item);
      map.set(key, list);
      return map;
    }, new Map<number, PickFileItem[]>())
    .entries()
)
  .sort(([left], [right]) => right - left)
  .map(([year, items]) => ({
    year,
    items
  }));

const groups: TocGroup[] = pickFileGroups.map((group) => ({
  title: String(group.year),
  items: group.items.map((item) => ({
    text: item.tocText,
    slug: item.id
  }))
}));
if (plannedPickFileItems.length > 0) {
  groups.unshift({
    title: PLANNED_READS_TITLE,
    items: plannedPickFileItems.map((item) => ({
      text: item.tocText,
      slug: item.id
    }))
  });
}
const hasPickList = plannedPickFileItems.length > 0 || pickFileGroups.length > 0;
---

<BaseLayout
  title={readsTitle}
  description="分享值得一读的书单和简短理由。"
  bodyClass="picks-page immersive-page"
>
  <div class="page-header page-header--picks reader-exit-anchor">
    <div class="page-heading">
      <h1 class="page-title">{readsTitle}</h1>
      {readsSubtitle ? <span class="page-subtitle">{readsSubtitle}</span> : null}
    </div>
    <div class="picks-header-actions">
      <div class="picks-search-cluster">
        <div class="entry-search picks-entry-search" data-picks-search-root>
          <form
            class="entry-search-panel picks-search-panel"
            role="search"
            data-picks-search-form
            data-picks-search-panel
            aria-hidden="true"
          >
            <label class="sr-only" for="picks-search">搜索拾选</label>
            <input
              id="picks-search"
              type="search"
              placeholder="搜索：关键词 / 标签"
              autocomplete="off"
              enterkeyhint="search"
              aria-controls="picks-search-results-panel"
              tabindex="-1"
            />
          </form>
          <span class="entry-search-bridge" aria-hidden="true"></span>
          <button
            class="entry-search-toggle"
            data-picks-search-toggle
            type="button"
            aria-label="搜索拾选"
            aria-expanded="false"
            aria-controls="picks-search"
          >
            <UiIcon name="search" class="icon" />
          </button>
        </div>
      </div>
    </div>
    <button
      id="reader-exit"
      class="icon-button reader-exit"
      type="button"
      aria-label="退出阅读"
      title="退出阅读"
      aria-hidden="true"
      tabindex="-1"
    >
      <UiIcon name="reader-exit" class="icon" />
    </button>
  </div>

  <div class="picks-search-status" id="picks-search-status"></div>
  <p class="sr-only" id="picks-search-live" role="status" aria-live="polite" aria-atomic="true"></p>

  <div data-picks-browse>
    <div class="intro">
      {readsIntro.map((line, index) => (
        <>
          {index > 0 ? <br /> : null}
          {line}
        </>
      ))}
    </div>

    {hasPickList ? (
      <>
        <nav class="picks-toc" aria-label="目录">
          {groups.map((g) => (
            <details open>
              <summary>{g.title}</summary>
              <ul class="toc-items">
                {g.items.map((it, i) => (
                  <li>
                    <a href={`#${it.slug}`}>
                      <span class="toc-num">{i + 1}</span>
                      <span>{it.text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </nav>

        <div class="picks-content prose heti" id="picks-content">
          {pickFileGroups.map((group) => (
            <>
              <h2>{group.year}</h2>
              {group.items.map((item) => (
                <>
                  <h3 id={item.id}>{item.title}</h3>
                  <item.Content />
                  {item.tags.length ? (
                    <p class="pick-tags" aria-label="标签">
                      {item.tags.map((tag) => (
                        <span class="pick-tag">#{tag.replace(/^#+/, '')}</span>
                      ))}
                    </p>
                  ) : null}
                </>
              ))}
            </>
          ))}
          {plannedPickFileItems.length ? (
            <>
              <h2 class="picks-planned-heading">{PLANNED_READS_TITLE}</h2>
              {plannedPickFileItems.map((item) => (
                <>
                  <h3 id={item.id} class="picks-planned-title">{item.title}</h3>
                  {item.tags.length ? (
                    <p class="pick-tags" aria-label="标签">
                      {item.tags.map((tag) => (
                        <span class="pick-tag">#{tag.replace(/^#+/, '')}</span>
                      ))}
                    </p>
                  ) : null}
                </>
              ))}
            </>
          ) : null}
        </div>
      </>
    ) : (
      <EmptyState message="暂无拾选分享" />
    )}
  </div>

  <section
    id="picks-search-results-panel"
    class="bits-search-results picks-search-results"
    data-picks-search-results
    hidden
    aria-label="搜索结果"
  >
    <div class="bits-search-results__header">
      <p class="bits-search-results__summary" data-picks-search-results-summary role="status" aria-live="polite">
        搜索结果
      </p>
      <button class="bits-search-results__clear" type="button" data-picks-search-clear>重置筛选</button>
    </div>
    <div class="bits-search-results__list" data-picks-search-results-list></div>
  </section>

  <script is:inline>
    (() => {
      const mq = window.matchMedia('(max-width: 640px)');
      const sync = () => {
        if (mq.matches) {
          document.querySelectorAll('.picks-toc details[open]').forEach((el) => {
            el.removeAttribute('open');
          });
        } else {
          document.querySelectorAll('.picks-toc details:not([open])').forEach((el) => {
            el.setAttribute('open', '');
          });
        }
      };
      sync();
      mq.addEventListener('change', sync);

      const content = document.querySelector('.picks-content');
      if (content) {
        const nodes = content.querySelectorAll('h2, h3');
        let count = 0;
        nodes.forEach((node) => {
          if (node.tagName === 'H2') {
            count = 0;
            return;
          }
          if (node.tagName === 'H3') {
            count += 1;
            node.setAttribute('data-num', String(count));
          }
        });
      }
    })();
  </script>

  <Lightbox
    id="lightbox"
    label="图片预览"
    enableZoom={false}
    enablePan={false}
    enableSwipeDownClose={false}
  />

  <script>
    import { initHeti } from '../../scripts/heti';
    import { initArticleLightbox, initCodeCopyButtons } from '../../scripts/lightbox';
    import '../../scripts/picks-search';

    initHeti();
    initCodeCopyButtons();
    initArticleLightbox({
      dialogId: 'lightbox',
      containerSelector: '.picks-content.prose',
      enableZoom: false,
      enablePan: false,
      enableSwipeDownClose: false
    });
  </script>
</BaseLayout>
