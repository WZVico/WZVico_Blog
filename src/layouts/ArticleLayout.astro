---
import BaseLayout from './BaseLayout.astro';
import type { MarkdownHeading } from 'astro';
import UiIcon from '../components/UiIcon.astro';
import Lightbox from '../components/Lightbox.astro';
import '../styles/article.css';
import { getArchiveAuthorHref } from '../lib/archive-links';
import { getLongformDerivedText, type LongformEntry } from '../lib/content';
import { containsMarkdownMath } from '../lib/markdown-math';
import {
  MARKDOWN_MATH_STYLESHEET_DATA_ATTR,
  MARKDOWN_MATH_STYLESHEET_HREF,
  MARKDOWN_MATH_STYLESHEET_ID
} from '../lib/markdown-math-styles';
import { getThemeSettings, type ArticleMetaSettings, type SidebarNavId } from '../lib/theme-settings';
import { getLongformArticlePeople } from '../lib/longform-people';
import { createWithBase, formatISODateUtc } from '../utils/format';
import { truncateText } from '../utils/excerpt';
import { countReadableTextUnits, getEstimatedReadingMinutes } from '../utils/reading-stats';

type ArticleNeighborLink = {
  href: string;
  title: string;
};

const {
  entry,
  prev,
  next,
  articleMetaSettings,
  headings = [],
  visibleTags = []
} = Astro.props as {
  entry: LongformEntry;
  prev: ArticleNeighborLink | null;
  next: ArticleNeighborLink | null;
  articleMetaSettings: ArticleMetaSettings;
  headings?: MarkdownHeading[];
  visibleTags?: string[];
};

const entryTags: string[] = entry?.data?.tags ?? [];
const defaultImage = '/og.svg';
const coverImage = entry?.data?.cover ?? null;
const ogImage = coverImage ?? defaultImage;
const derivedText = getLongformDerivedText(entry);
const rawDescription = entry?.data?.description?.trim?.() ?? '';
const description = rawDescription || truncateText(derivedText.excerpt, 90);
const activeNavId: SidebarNavId = entry?.data?.archive === false ? 'longform' : 'archive';
const hasMath = containsMarkdownMath(entry.body ?? '');
const katexStylesheetAttrs = { [MARKDOWN_MATH_STYLESHEET_DATA_ATTR]: 'true' };
const articleReadingStats = articleMetaSettings.showWordCount || articleMetaSettings.showReadingTime
  ? (() => {
      const wordCount = countReadableTextUnits(derivedText.plainText);
      return {
        wordCount,
        readingMinutes: getEstimatedReadingMinutes(wordCount)
      };
    })()
  : { wordCount: 0, readingMinutes: 0 };
const numberFormatter = new Intl.NumberFormat('zh-CN');
const readingStatsMetaText = [
  articleMetaSettings.showWordCount ? `共 ${numberFormatter.format(articleReadingStats.wordCount)} 字` : '',
  articleMetaSettings.showReadingTime ? `约 ${numberFormatter.format(articleReadingStats.readingMinutes)} 分钟` : ''
].filter(Boolean).join('，');
const publishedDateText = formatISODateUtc(entry.data.date);
const updatedAt = entry.data.updatedAt instanceof Date && Number.isFinite(entry.data.updatedAt.valueOf())
  ? entry.data.updatedAt
  : null;
const updatedDateText = updatedAt ? formatISODateUtc(updatedAt) : '';
const shouldShowUpdatedDate = articleMetaSettings.showDate
  && updatedAt !== null
  && updatedDateText !== publishedDateText;
const withBase = createWithBase(import.meta.env.BASE_URL ?? '/');
const { settings } = getThemeSettings();
const { authors: articleAuthors, translator: translatorPerson } = getLongformArticlePeople(entry, settings, withBase);
const shouldShowAuthorMeta = articleAuthors.length > 0;
const shouldShowTranslatorMeta = Boolean(translatorPerson);
const shouldShowMetaLine = shouldShowAuthorMeta
  || shouldShowTranslatorMeta
  || articleMetaSettings.showDate
  || (articleMetaSettings.showTags && visibleTags.length > 0)
  || articleMetaSettings.showWordCount
  || articleMetaSettings.showReadingTime;
const translation = entry.data.translation;
const translationSource = translation?.source?.trim() ?? '';
const translationSourceUrl = translation?.sourceUrl?.trim() ?? '';
const translationSourceLabel = translationSource || (translationSourceUrl ? '原文' : '');
const articleTocItems = headings
  .filter((heading) =>
    heading.depth >= 1
    && heading.depth <= 6
    && typeof heading.slug === 'string'
    && heading.slug.trim().length > 0
    && heading.text.trim().length > 0
  )
  .map((heading) => ({
    depth: heading.depth,
    slug: heading.slug,
    text: heading.text.trim()
  }));
const shouldShowArticleToc = articleTocItems.length > 0;

---

<BaseLayout
  title={entry.data.title}
  description={description}
  image={ogImage}
  ogType="article"
  bodyClass="article-page immersive-page"
  activeNavId={activeNavId}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={entry.data.date.toISOString()} />
    {updatedAt ? <meta property="article:modified_time" content={updatedAt.toISOString()} /> : null}
    {articleAuthors.map((author) => (
      <meta property="article:author" content={author.name} />
    ))}
    {entryTags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
    {hasMath ? (
      <link
        id={MARKDOWN_MATH_STYLESHEET_ID}
        rel="stylesheet"
        href={MARKDOWN_MATH_STYLESHEET_HREF}
        {...katexStylesheetAttrs}
      />
    ) : null}
  </Fragment>
  <div class="article-header reader-exit-anchor">
    <h1 class="page-title">{entry.data.title}</h1>
    <button
      id="reader-exit"
      class="icon-button reader-exit"
      type="button"
      aria-label="退出阅读"
      title="退出阅读"
      aria-hidden="true"
      tabindex="-1"
    >
      <UiIcon name="reader-exit" class="icon" />
    </button>
    {shouldShowMetaLine ? (
      <div class="meta-line meta-line--items">
        {shouldShowAuthorMeta ? (
          <span class="meta-line__item meta-line__item--person article-meta-person article-meta-person--authors">
            <span class="article-byline__label">作者</span>
            <span class="article-author-list">
              {articleAuthors.map((author) => (
                <span class="article-author">
                  {author.showAvatar ? (
                    <span class="article-author-avatar article-author-avatar--image" aria-hidden="true">
                      <img
                        src={author.avatar}
                        alt=""
                        width="32"
                        height="32"
                        loading="lazy"
                        decoding="async"
                        onerror="this.parentElement?.remove();"
                      />
                    </span>
                  ) : null}
                  <a
                    class="article-byline__name article-byline__name--link"
                    href={getArchiveAuthorHref(author.name, withBase)}
                    aria-label={`查看 ${author.name} 的所有文章`}
                  >
                    {author.name}
                  </a>
                </span>
              ))}
            </span>
          </span>
        ) : null}
        {translatorPerson ? (
          <span class="meta-line__item meta-line__item--person article-meta-person article-meta-person--translator">
            <span class="article-byline__label">翻译</span>
            <span class="article-author">
              {translatorPerson.showAvatar ? (
                <span class="article-author-avatar article-author-avatar--image" aria-hidden="true">
                  <img
                    src={translatorPerson.avatar}
                    alt=""
                    width="32"
                    height="32"
                    loading="lazy"
                    decoding="async"
                    onerror="this.parentElement?.remove();"
                  />
                </span>
              ) : null}
              <span class="article-byline__name">{translatorPerson.name}</span>
            </span>
          </span>
        ) : null}
        {articleMetaSettings.showDate ? (
          <span class="meta-line__item">
            {articleMetaSettings.dateLabel ? `${articleMetaSettings.dateLabel}` : ''}{publishedDateText}
          </span>
        ) : null}
        {shouldShowUpdatedDate ? (
          <span class="meta-line__item">
            更新于：{updatedDateText}
          </span>
        ) : null}
        {readingStatsMetaText ? (
          <span class="meta-line__item meta-line__item--desktop-meta meta-line__item--reading-stats">
            {readingStatsMetaText}
          </span>
        ) : null}
        {articleMetaSettings.showTags && visibleTags.length ? (
          <span class="meta-line__item meta-line__item--tags">
            {visibleTags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </span>
        ) : null}
      </div>
    ) : null}
    {translationSourceLabel ? (
      <div class="article-source-line">
        <span>文章来源：</span>
        {translationSourceUrl ? (
          <a href={translationSourceUrl} rel="noopener noreferrer" target="_blank">{translationSourceLabel}</a>
        ) : (
          <span>{translationSourceLabel}</span>
        )}
      </div>
    ) : null}
    {shouldShowArticleToc ? (
      <details class="article-toc" data-article-toc>
        <summary class="article-toc__summary">
          <span class="article-toc__title">目录</span>
          <span class="article-toc__count">{articleTocItems.length}</span>
        </summary>
        <ol class="article-toc__list">
          {articleTocItems.map((heading) => (
            <li class={`article-toc__item article-toc__item--depth-${heading.depth}`}>
              <a class="article-toc__link" href={`#${heading.slug}`} data-article-toc-link={heading.slug}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </details>
    ) : null}
  </div>

  <div class="prose heti">
    <slot />
  </div>
  {(prev || next) ? (
    <nav class="prev-next" aria-label="上一篇/下一篇">
      <div class="prev-next__item">
        {prev ? (
          <a class="prev-next__link prev-next__link--prev" href={prev.href} rel="prev">
            <span class="prev-next__label">上一篇</span>
            <span class="prev-next__title">{prev.title}</span>
          </a>
        ) : (
          <span class="prev-next__placeholder" aria-hidden="true"></span>
        )}
      </div>
      <div class="prev-next__item">
        {next ? (
          <a class="prev-next__link prev-next__link--next" href={next.href} rel="next">
            <span class="prev-next__label">下一篇</span>
            <span class="prev-next__title">{next.title}</span>
          </a>
        ) : (
          <span class="prev-next__placeholder" aria-hidden="true"></span>
        )}
      </div>
    </nav>
  ) : null}

  <Lightbox
    id="lightbox"
    label="图片预览"
    enableZoom={false}
    enablePan={false}
    enableSwipeDownClose={false}
  />

  <script>
    import { initHeti } from '../scripts/heti';
    import { initArticleLightbox, initCodeCopyButtons } from '../scripts/lightbox';

    initHeti();
    initCodeCopyButtons();
    initArticleLightbox({
      dialogId: 'lightbox',
      containerSelector: '.prose',
      enableZoom: false,
      enablePan: false,
      enableSwipeDownClose: false
    });

    const articleToc = document.querySelector<HTMLDetailsElement>('[data-article-toc]');
    const wideTocQuery = window.matchMedia('(min-width: 1360px)');
    const tocTargets = Array.from(
      articleToc?.querySelectorAll<HTMLAnchorElement>('[data-article-toc-link]') ?? []
    ).map((link) => {
      const id = link.dataset.articleTocLink ?? '';
      const target = document.getElementById(id) ?? document.getElementById(`user-content-${id}`);
      return target ? { link, target, item: link.closest('.article-toc__item') } : null;
    }).filter((item): item is { link: HTMLAnchorElement; target: HTMLElement; item: Element | null } => item !== null);
    let activeTocLink: HTMLAnchorElement | null = null;
    let activeTocItem: Element | null = null;
    let tocUpdateFrame = 0;

    const setActiveTocLink = (link: HTMLAnchorElement | null, item: Element | null = null) => {
      if (link === activeTocLink) return;
      activeTocLink?.classList.remove('is-active');
      activeTocLink?.removeAttribute('aria-current');
      activeTocItem?.classList.remove('is-active');
      activeTocLink = link;
      activeTocItem = item;
      activeTocLink?.classList.add('is-active');
      activeTocLink?.setAttribute('aria-current', 'location');
      activeTocItem?.classList.add('is-active');
      activeTocLink?.scrollIntoView({ block: 'nearest', inline: 'nearest' });
    };

    const updateActiveTocLink = () => {
      tocUpdateFrame = 0;
      if (tocTargets.length === 0) return;
      const marker = Math.max(96, window.innerHeight * 0.24);
      const nearDocumentEnd = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
      let activeTarget = nearDocumentEnd ? tocTargets[tocTargets.length - 1] : null;

      if (!activeTarget) {
        for (const tocTarget of tocTargets) {
          if (tocTarget.target.getBoundingClientRect().top <= marker) {
            activeTarget = tocTarget;
            continue;
          }
          break;
        }
      }

      setActiveTocLink(activeTarget?.link ?? null, activeTarget?.item ?? null);
    };

    const scheduleActiveTocUpdate = () => {
      if (tocUpdateFrame) return;
      tocUpdateFrame = window.requestAnimationFrame(updateActiveTocLink);
    };

    const syncArticleTocState = () => {
      if (!articleToc) return;
      articleToc.open = wideTocQuery.matches;
      scheduleActiveTocUpdate();
    };

    syncArticleTocState();
    wideTocQuery.addEventListener('change', syncArticleTocState);
    window.addEventListener('scroll', scheduleActiveTocUpdate, { passive: true });
    window.addEventListener('resize', scheduleActiveTocUpdate);
    window.addEventListener('hashchange', () => window.setTimeout(scheduleActiveTocUpdate, 120));
    articleToc?.addEventListener('click', (event) => {
      const target = event.target instanceof Element
        ? event.target.closest<HTMLAnchorElement>('.article-toc__link')
        : null;
      if (!target) return;
      setActiveTocLink(target, target.closest('.article-toc__item'));
      if (!wideTocQuery.matches) articleToc.open = false;
    });
  </script>
</BaseLayout>
