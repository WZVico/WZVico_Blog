---
import BaseLayout from './BaseLayout.astro';
import UiIcon from '../components/UiIcon.astro';
import Lightbox from '../components/Lightbox.astro';
import '../styles/article.css';
import { getArchiveAuthorHref } from '../lib/archive-links';
import { getLongformDerivedText, type LongformEntry } from '../lib/content';
import { containsMarkdownMath } from '../lib/markdown-math';
import {
  MARKDOWN_MATH_STYLESHEET_DATA_ATTR,
  MARKDOWN_MATH_STYLESHEET_HREF,
  MARKDOWN_MATH_STYLESHEET_ID
} from '../lib/markdown-math-styles';
import { getThemeSettings, type ArticleMetaSettings, type SidebarNavId } from '../lib/theme-settings';
import { getLongformArticlePeople } from '../lib/longform-people';
import { createWithBase, formatISODateUtc } from '../utils/format';
import { truncateText } from '../utils/excerpt';
import { countReadableTextUnits, getEstimatedReadingMinutes } from '../utils/reading-stats';

type ArticleNeighborLink = {
  href: string;
  title: string;
};

const {
  entry,
  prev,
  next,
  articleMetaSettings,
  visibleTags = []
} = Astro.props as {
  entry: LongformEntry;
  prev: ArticleNeighborLink | null;
  next: ArticleNeighborLink | null;
  articleMetaSettings: ArticleMetaSettings;
  visibleTags?: string[];
};

const entryTags: string[] = entry?.data?.tags ?? [];
const defaultImage = '/og.svg';
const coverImage = entry?.data?.cover ?? null;
const ogImage = coverImage ?? defaultImage;
const derivedText = getLongformDerivedText(entry);
const rawDescription = entry?.data?.description?.trim?.() ?? '';
const description = rawDescription || truncateText(derivedText.excerpt, 90);
const activeNavId: SidebarNavId = entry?.data?.archive === false ? 'longform' : 'archive';
const hasMath = containsMarkdownMath(entry.body ?? '');
const katexStylesheetAttrs = { [MARKDOWN_MATH_STYLESHEET_DATA_ATTR]: 'true' };
const articleReadingStats = articleMetaSettings.showWordCount || articleMetaSettings.showReadingTime
  ? (() => {
      const wordCount = countReadableTextUnits(derivedText.plainText);
      return {
        wordCount,
        readingMinutes: getEstimatedReadingMinutes(wordCount)
      };
    })()
  : { wordCount: 0, readingMinutes: 0 };
const numberFormatter = new Intl.NumberFormat('zh-CN');
const readingStatsMetaText = [
  articleMetaSettings.showWordCount ? `共 ${numberFormatter.format(articleReadingStats.wordCount)} 字` : '',
  articleMetaSettings.showReadingTime ? `约 ${numberFormatter.format(articleReadingStats.readingMinutes)} 分钟` : ''
].filter(Boolean).join('，');
const withBase = createWithBase(import.meta.env.BASE_URL ?? '/');
const { settings } = getThemeSettings();
const { authors: articleAuthors, translator: translatorPerson } = getLongformArticlePeople(entry, settings, withBase);
const shouldShowPeopleMeta = articleAuthors.length > 0 || Boolean(translatorPerson);
const shouldShowMetaLine = shouldShowPeopleMeta
  || articleMetaSettings.showDate
  || (articleMetaSettings.showTags && visibleTags.length > 0)
  || articleMetaSettings.showWordCount
  || articleMetaSettings.showReadingTime;
const translation = entry.data.translation;
const translationSource = translation?.source?.trim() ?? '';
const translationSourceUrl = translation?.sourceUrl?.trim() ?? '';
const translationSourceLabel = translationSource || (translationSourceUrl ? '原文' : '');

---

<BaseLayout
  title={entry.data.title}
  description={description}
  image={ogImage}
  ogType="article"
  bodyClass="article-page immersive-page"
  activeNavId={activeNavId}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={entry.data.date.toISOString()} />
    {articleAuthors.map((author) => (
      <meta property="article:author" content={author.name} />
    ))}
    {entryTags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
    {hasMath ? (
      <link
        id={MARKDOWN_MATH_STYLESHEET_ID}
        rel="stylesheet"
        href={MARKDOWN_MATH_STYLESHEET_HREF}
        {...katexStylesheetAttrs}
      />
    ) : null}
  </Fragment>
  <div class="article-header reader-exit-anchor">
    <h1 class="page-title">{entry.data.title}</h1>
    <button
      id="reader-exit"
      class="icon-button reader-exit"
      type="button"
      aria-label="退出阅读"
      title="退出阅读"
      aria-hidden="true"
      tabindex="-1"
    >
      <UiIcon name="reader-exit" class="icon" />
    </button>
    {shouldShowMetaLine ? (
      <div class="meta-line meta-line--items">
        {shouldShowPeopleMeta ? (
          <span class="meta-line__item meta-line__item--people article-meta-people">
            {articleAuthors.length ? (
              <>
                <span class="article-byline__label">作者</span>
                <span class="article-author-list">
                  {articleAuthors.map((author) => (
                    <span class="article-author">
                      {author.showAvatar ? (
                        <span class="article-author-avatar article-author-avatar--image" aria-hidden="true">
                          <img
                            src={author.avatar}
                            alt=""
                            width="32"
                            height="32"
                            loading="lazy"
                            decoding="async"
                            onerror="this.parentElement?.remove();"
                          />
                        </span>
                      ) : null}
                      <a
                        class="article-byline__name article-byline__name--link"
                        href={getArchiveAuthorHref(author.name, withBase)}
                        aria-label={`查看 ${author.name} 的所有文章`}
                      >
                        {author.name}
                      </a>
                    </span>
                  ))}
                </span>
              </>
            ) : null}
            {translatorPerson ? (
              <span class="article-translator">
                <span class="article-byline__label">翻译</span>
                <span class="article-author">
                  {translatorPerson.showAvatar ? (
                    <span class="article-author-avatar article-author-avatar--image" aria-hidden="true">
                      <img
                        src={translatorPerson.avatar}
                        alt=""
                        width="32"
                        height="32"
                        loading="lazy"
                        decoding="async"
                        onerror="this.parentElement?.remove();"
                      />
                    </span>
                  ) : null}
                  <span class="article-byline__name">{translatorPerson.name}</span>
                </span>
              </span>
            ) : null}
          </span>
        ) : null}
        {articleMetaSettings.showDate ? (
          <span class="meta-line__item">
            {articleMetaSettings.dateLabel ? `${articleMetaSettings.dateLabel}` : ''}{formatISODateUtc(entry.data.date)}
          </span>
        ) : null}
        {readingStatsMetaText ? (
          <span class="meta-line__item meta-line__item--desktop-meta meta-line__item--reading-stats">
            {readingStatsMetaText}
          </span>
        ) : null}
        {articleMetaSettings.showTags && visibleTags.length ? (
          <span class="meta-line__item meta-line__item--tags">
            {visibleTags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </span>
        ) : null}
      </div>
    ) : null}
    {translationSourceLabel ? (
      <div class="article-source-line">
        <span>文章来源：</span>
        {translationSourceUrl ? (
          <a href={translationSourceUrl} rel="noopener noreferrer" target="_blank">{translationSourceLabel}</a>
        ) : (
          <span>{translationSourceLabel}</span>
        )}
      </div>
    ) : null}
  </div>

  <div class="prose heti">
    <slot />
  </div>
  {(prev || next) ? (
    <nav class="prev-next" aria-label="上一篇/下一篇">
      <div class="prev-next__item">
        {prev ? (
          <a class="prev-next__link prev-next__link--prev" href={prev.href} rel="prev">
            <span class="prev-next__label">上一篇</span>
            <span class="prev-next__title">{prev.title}</span>
          </a>
        ) : (
          <span class="prev-next__placeholder" aria-hidden="true"></span>
        )}
      </div>
      <div class="prev-next__item">
        {next ? (
          <a class="prev-next__link prev-next__link--next" href={next.href} rel="next">
            <span class="prev-next__label">下一篇</span>
            <span class="prev-next__title">{next.title}</span>
          </a>
        ) : (
          <span class="prev-next__placeholder" aria-hidden="true"></span>
        )}
      </div>
    </nav>
  ) : null}

  <Lightbox
    id="lightbox"
    label="图片预览"
    enableZoom={false}
    enablePan={false}
    enableSwipeDownClose={false}
  />

  <script>
    import { initHeti } from '../scripts/heti';
    import { initArticleLightbox, initCodeCopyButtons } from '../scripts/lightbox';

    initHeti();
    initCodeCopyButtons();
    initArticleLightbox({
      dialogId: 'lightbox',
      containerSelector: '.prose',
      enableZoom: false,
      enablePan: false,
      enableSwipeDownClose: false
    });
  </script>
</BaseLayout>
