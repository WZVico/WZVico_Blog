---
import Sidebar from '../components/Sidebar.astro';
import UiIcon from '../components/UiIcon.astro';
import globalStylesHref from '../styles/global.css?url';
import { hasSiteUrl } from '../../site.config.mjs';
import { ADMIN_SIDEBAR_NAV_MODE_STORAGE_KEY } from '../lib/admin-console/ui-prefs-keys';
import { createWithBase } from '../utils/format';
import { getThemeSettings, type SidebarNavId } from '../lib/theme-settings';

const {
  title,
  description,
  image,
  ogType = 'website',
  bodyClass,
  deferGlobalStyles = false,
  enableShellScripts = true,
  activeNavId
} = Astro.props as {
  title?: string;
  description?: string;
  image?: string;
  ogType?: string;
  bodyClass?: string;
  deferGlobalStyles?: boolean;
  enableShellScripts?: boolean;
  activeNavId?: SidebarNavId;
};

const { settings } = getThemeSettings();
const siteTitle = settings.site.title;
const siteFavicon = settings.site.favicon;
const brandTitle = settings.shell.brandTitle ?? siteTitle;
const metaDescription = description ?? settings.site.description;
const fullTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const htmlLang = settings.site.defaultLocale || 'zh-CN';
const footerStartYear = settings.site.footer.startYear;
const footerShowCurrentYear = settings.site.footer.showCurrentYear;
const footerCopyright = settings.site.footer.copyright;
const showCodeLineNumbers = settings.ui.codeBlock.showLineNumbers;
const sidebarDividerVariant = settings.ui.layout.sidebarDivider;
const isDev = import.meta.env.DEV;
const showDevSidebarNav = isDev && enableShellScripts;
const canonical = (hasSiteUrl && Astro.site)
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : null;
const ogImage = image
  ? ((hasSiteUrl && Astro.site) ? new URL(image, Astro.site).toString() : image)
  : null;
const currentYear = new Date().getFullYear();
const yearRange = footerShowCurrentYear && currentYear > footerStartYear
  ? `${footerStartYear}-${currentYear}`
  : `${footerStartYear}`;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const getFaviconType = (src: string): string | null => {
  const pathname = src.split(/[?#]/, 1)[0]?.toLowerCase() ?? '';
  if (pathname.endsWith('.svg')) return 'image/svg+xml';
  if (pathname.endsWith('.png')) return 'image/png';
  if (pathname.endsWith('.ico')) return 'image/x-icon';
  if (pathname.endsWith('.webp')) return 'image/webp';
  if (pathname.endsWith('.avif')) return 'image/avif';
  if (pathname.endsWith('.gif')) return 'image/gif';
  if (pathname.endsWith('.jpg') || pathname.endsWith('.jpeg')) return 'image/jpeg';
  return null;
};
const siteFaviconType = siteFavicon ? getFaviconType(siteFavicon) : null;
const adminSidebarNavModeStylesHref = showDevSidebarNav
  ? (await import('../styles/components/admin-dev-sidebar-nav.css?url')).default
  : null;
const adminSidebarNavModeScriptHref = showDevSidebarNav
  ? (await import('../scripts/admin-sidebar-nav-mode.ts?url')).default
  : null;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <script is:inline>
      (() => {
        // Keep this contract aligned with src/scripts/sidebar-theme.ts so first paint and runtime agree.
        const themeKey = 'theme';
        const modeKey = 'theme-mode';
        let storedMode = null;
        let legacyTheme = null;
        try {
          storedMode = localStorage.getItem(modeKey);
          legacyTheme = localStorage.getItem(themeKey);
        } catch (_) {}
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const mode = storedMode === 'system' || storedMode === 'dark' || storedMode === 'light'
          ? storedMode
          : (legacyTheme === 'dark' || legacyTheme === 'light' ? legacyTheme : 'system');
        const theme = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.themeMode = mode;
      })();
    </script>
    {showDevSidebarNav ? (
      <script
        is:inline
        define:vars={{ sidebarNavModeKey: ADMIN_SIDEBAR_NAV_MODE_STORAGE_KEY }}
      >
        (() => {
          const root = document.documentElement;
          let storedNavMode = null;
          try {
            storedNavMode = sessionStorage.getItem(sidebarNavModeKey);
          } catch (_) {}
          root.dataset.adminNavMode = storedNavMode === 'admin' ? 'admin' : 'public';
        })();
      </script>
    ) : null}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      siteFavicon ? (
        <link rel="icon" type={siteFaviconType ?? undefined} href={withBase(siteFavicon)} />
      ) : (
        <>
          <link rel="icon" type="image/svg+xml" sizes="any" href={withBase('favicon.svg')} />
          <link rel="icon" type="image/png" sizes="96x96" href={withBase('favicon-96x96.png')} />
          <link rel="apple-touch-icon" sizes="180x180" href={withBase('apple-touch-icon.png')} />
        </>
      )
    }
    <title>{fullTitle}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={fullTitle} />
    {metaDescription && <meta property="og:description" content={metaDescription} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    {metaDescription && <meta name="twitter:description" content={metaDescription} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {
      deferGlobalStyles ? (
        <>
          <link rel="preload" href={globalStylesHref} as="style" />
          <link
            rel="stylesheet"
            href={globalStylesHref}
            media="print"
            onload="this.onload=null;this.media='all'"
          />
          <noscript><link rel="stylesheet" href={globalStylesHref} /></noscript>
        </>
      ) : (
        <link rel="stylesheet" href={globalStylesHref} />
      )
    }
    {adminSidebarNavModeStylesHref ? <link rel="stylesheet" href={adminSidebarNavModeStylesHref} /> : null}
    <slot name="head" />
  </head>
  <body
    class={bodyClass}
    data-code-line-numbers={showCodeLineNumbers ? undefined : 'off'}
    data-dev-ui={showDevSidebarNav ? 'true' : undefined}
  >
    <a class="skip-link" href="#content">跳到内容</a>
    <div class="shell" data-sidebar-divider={sidebarDividerVariant}>
      <Sidebar siteTitle={brandTitle} activeNavId={activeNavId} isDev={showDevSidebarNav} />
      <div class="divider" aria-hidden="true"></div>
      <main id="content" class="content" tabindex="-1">
        <div class="content__inner">
          <slot />
          <footer class="site-footer">© {yearRange} {footerCopyright}</footer>
        </div>
      </main>
    </div>
    <template id="scroll-top-template">
      <button
        type="button"
        class="icon-button float-action scroll-top"
        aria-label="回到页首"
        title="回到页首"
        aria-hidden="true"
        tabindex="-1"
      >
        <UiIcon name="chevron-up" class="icon" />
      </button>
    </template>
    {
      enableShellScripts ? (
        <script>
          import '../scripts/hash-anchor.ts';
          import '../scripts/sidebar-theme.ts';
          import '../scripts/meta-line.ts';
        </script>
      ) : null
    }
    {adminSidebarNavModeScriptHref ? (
      <script is:inline type="module" src={adminSidebarNavModeScriptHref}></script>
    ) : null}
  </body>
</html>
