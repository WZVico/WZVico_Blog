---
import UiIcon from './UiIcon.astro';
import { getThemeSettings } from '../lib/theme-settings';
import type { AdminCategoryEntryPayload } from '../lib/admin-console/category-entry';

const { settings } = getThemeSettings();
const {
  createEndpoint = '',
  inline = false,
  editPayload = null,
  editEndpoint = '',
  clearEditHref = ''
} = Astro.props as {
  createEndpoint?: string;
  inline?: boolean;
  editPayload?: AdminCategoryEntryPayload | null;
  editEndpoint?: string;
  clearEditHref?: string;
};
const RootTag = inline ? 'section' : 'dialog';
const isEditMode = editPayload?.collection === 'bits';
const getEditText = (key: string): string => {
  const value = editPayload?.values[key];
  return typeof value === 'string' ? value : '';
};
const getEditChecked = (key: string): boolean => editPayload?.values[key] === true;
const parseEditImages = (value: string): { src: string; width: string; height: string }[] => {
  try {
    const parsed = JSON.parse(value) as unknown;
    if (!Array.isArray(parsed)) return [];
    return parsed
      .filter((item): item is Record<string, unknown> => typeof item === 'object' && item !== null && !Array.isArray(item))
      .map((item) => ({
        src: typeof item.src === 'string' ? item.src : '',
        width: typeof item.width === 'number' || typeof item.width === 'string' ? String(item.width) : '',
        height: typeof item.height === 'number' || typeof item.height === 'string' ? String(item.height) : ''
      }))
      .filter((item) => item.src || item.width || item.height);
  } catch {
    return [];
  }
};
const editImages = isEditMode ? parseEditImages(getEditText('imagesText')) : [];
const imageRows = editImages.length > 0 ? editImages : [{ src: '', width: '', height: '' }];
---
<RootTag
  class:list={['bits-draft-dialog', inline && 'bits-draft-dialog--inline']}
  id="bits-draft-dialog"
  aria-labelledby="bits-draft-title"
  data-bits-draft-inline={inline ? 'true' : undefined}
  data-bits-draft-create-endpoint={createEndpoint || undefined}
  data-bits-edit-endpoint={isEditMode ? editEndpoint : undefined}
  data-bits-edit-collection={isEditMode ? editPayload.collection : undefined}
  data-bits-edit-id={isEditMode ? editPayload.entryId : undefined}
  data-bits-edit-revision={isEditMode ? editPayload.revision : undefined}
  data-default-author-name={settings.page.bits.defaultAuthor.name ?? ''}
  data-default-author-avatar={settings.page.bits.defaultAuthor.avatar ?? ''}
>
  <form class="bits-draft-form" data-bits-draft-form>
    <div class="bits-draft-head">
      <h2 id="bits-draft-title">
        <span class="bits-draft-title-icon" aria-hidden="true">
          <UiIcon name="pen" />
        </span>
        {isEditMode ? `编辑絮语：${editPayload.relativePath}` : '碎碎念'}
      </h2>
      {!inline ? <button class="bits-draft-close" type="button" data-bits-draft-close aria-label="关闭">×</button> : null}
    </div>

    {isEditMode ? (
      <div class="bits-draft-row">
        <div class="bits-draft-field bits-draft-half">
          <label for="bits-draft-title" class="bits-draft-label">标题</label>
          <input id="bits-draft-title" data-bits-edit-field="title" type="text" inputmode="text" value={getEditText('title')} />
        </div>
        <div class="bits-draft-field bits-draft-half">
          <label for="bits-draft-date" class="bits-draft-label">date *</label>
          <input id="bits-draft-date" data-bits-edit-field="date" type="text" inputmode="text" value={getEditText('date')} />
        </div>
        <div class="bits-draft-field bits-draft-half">
          <label for="bits-draft-slug" class="bits-draft-label">slug</label>
          <input id="bits-draft-slug" data-bits-edit-field="slug" type="text" inputmode="text" value={getEditText('slug')} />
        </div>
        <div class="bits-draft-field bits-draft-half">
          <label for="bits-draft-description" class="bits-draft-label">描述</label>
          <input id="bits-draft-description" data-bits-edit-field="description" type="text" inputmode="text" value={getEditText('description')} />
        </div>
      </div>
    ) : null}

    <div class="bits-draft-field">
      <div class="bits-draft-field-head">
        <label for="bits-draft-content">正文内容</label>
        <div class="bits-draft-toolbar" data-bits-draft-toolbar role="toolbar" aria-label="常用格式">
          <button type="button" class="bits-draft-tool" data-action="bold" data-tip="加粗" aria-label="加粗">
            <UiIcon name="bold" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="italic" data-tip="斜体" aria-label="斜体">
            <UiIcon name="italic" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="code" data-tip="行内代码" aria-label="行内代码">
            <UiIcon name="code" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="quote" data-tip="引用" aria-label="引用">
            <UiIcon name="quote" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="list" data-tip="列表" aria-label="列表">
            <UiIcon name="list" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="link" data-tip="链接" aria-label="链接">
            <UiIcon name="link" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="paragraph" data-tip="段落" aria-label="段落">
            <UiIcon name="paragraph" />
          </button>
        </div>
      </div>
      <textarea
        id="bits-draft-content"
        name="content"
        rows="6"
        required
        placeholder="写点什么…"
      >{getEditText('body')}</textarea>
    </div>

    <div class="bits-draft-row">
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-tags" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">#</span>
          标签
        </label>
        <input id="bits-draft-tags" name="tags" type="text" inputmode="text" placeholder="agent, Vibe coding" value={getEditText('tagsText')} />
        <div class="bits-draft-help">例：生活 阅读 / agent, Vibe coding</div>
      </div>
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-place" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">
            <UiIcon name="map-pin" />
          </span>
          地点（可选）
        </label>
        <input id="bits-draft-place" name="place" type="text" inputmode="text" placeholder="例如:上海" />
        <div class="bits-draft-help">生成 tags 里的 loc:&lt;地点&gt;</div>
      </div>
    </div>

    <div class="bits-draft-stack">
      <div class="bits-draft-field">
        <div class="bits-draft-field-head bits-draft-image-head">
          <div class="bits-draft-field-title">
            <label>插入图片（可选）</label>
            <button class="bits-draft-image-add" type="button" data-bits-image-add>+ 添加</button>
          </div>
          <div class="bits-draft-help">自动读取图片尺寸</div>
        </div>
        <div class="bits-draft-images" data-bits-images>
          {imageRows.map((image) => (
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/xxx.jpg 或 https://..."
                value={image.src}
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="移除图片">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="宽度"
              value={image.width}
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="高度"
              value={image.height}
            />
          </div>
          ))}
        </div>
        <template data-bits-image-template>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/xxx.jpg 或 https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="移除图片">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="宽度"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="高度"
            />
          </div>
        </template>
      </div>

      <div class="bits-draft-status" data-bits-draft-status role="status" aria-live="polite"></div>
      <div class="bits-draft-link-row">
        <button class="bits-draft-link" type="button" data-bits-manual-open hidden>
          <span class="bits-draft-link-icon" aria-hidden="true">
            <UiIcon name="eye" />
          </span>
          <span>预览草稿</span>
          <span class="bits-draft-link-caret" aria-hidden="true">
            <UiIcon name="chevron-down" />
          </span>
        </button>
      </div>

      <div class="bits-draft-manual" data-bits-manual hidden>
        <div class="bits-draft-manual-title">草稿内容（只读）</div>
        <textarea class="bits-draft-manual-textarea" data-bits-manual-textarea rows="6" readonly></textarea>
        <div class="bits-draft-manual-actions">
          <div class="bits-draft-manual-note" data-bits-manual-note></div>
          <button class="bits-draft-secondary" type="button" data-bits-manual-copy>手动复制</button>
        </div>
      </div>

      <div class="bits-identity-bar" data-identity-bar>
        <div class="bits-identity-caption">
          <span class="bits-identity-label-icon" aria-hidden="true">
            <UiIcon name="user-circle" />
          </span>
          <span id="bits-identity-heading">作者（可选）</span>
        </div>
        <div class="bits-identity-row">
          <div class="bits-identity-controls">
            <button
              class="bits-identity-pill"
              type="button"
              data-identity-pill
              aria-controls="bits-identity-panel"
              aria-expanded="false"
            >
              <span class="bits-identity-avatar" data-identity-avatar aria-hidden="true"></span>
              <span class="bits-identity-name" data-identity-name></span>
            </button>
          </div>
          <button
            class="bits-identity-new"
            type="button"
            data-identity-new
            aria-controls="bits-identity-panel"
            aria-expanded="false"
          >
            添加作者
          </button>
        </div>
      </div>

      <div
        id="bits-identity-panel"
        class="bits-identity-advanced"
        data-identity-panel
        role="group"
        aria-labelledby="bits-identity-heading"
        hidden
      >
        <div class="bits-identity-fields">
          <label class="bits-identity-label">
            <span class="bits-identity-label-title">作者名</span>
            <input type="text" name="authorName" inputmode="text" data-author-name value={getEditText('authorName')} />
            <span class="bits-identity-label-hint">多作者用顿号、逗号或分号分隔</span>
          </label>
          <label class="bits-identity-label">
            <span class="bits-identity-label-row">
              <span class="bits-identity-label-title">头像路径（URL）</span>
              <span class="bits-identity-label-hint">留空用默认头像；加载失败则显示首字符</span>
            </span>
            <input type="text" name="authorAvatar" inputmode="url" data-author-avatar value={getEditText('authorAvatar')} />
          </label>
        </div>
        <div class="bits-identity-meta">
          <p class="bits-identity-note">
            留空即用当前作者；多作者会写入 authors
          </p>
          <button type="button" class="bits-identity-reset" data-author-reset>恢复默认</button>
        </div>
      </div>
    </div>

    <div class="bits-draft-footer">
      <div class="bits-draft-check">
        <input id="bits-draft-draft" name="draft" type="checkbox" checked={getEditChecked('draft')} />
        <label for="bits-draft-draft">标记为草稿</label>
        <span class="bits-draft-check-help">草稿:线上/预览默认不显示</span>
      </div>
      <div class="bits-draft-actions">
        <button class="bits-draft-primary" type="button" data-bits-draft-generate>生成</button>
        {isEditMode ? <button class="bits-draft-primary" type="button" data-bits-edit-submit>保存修改</button> : null}
        {isEditMode ? <a class="bits-draft-secondary" href={clearEditHref}>放弃编辑</a> : null}
      </div>
    </div>
  </form>
</RootTag>
