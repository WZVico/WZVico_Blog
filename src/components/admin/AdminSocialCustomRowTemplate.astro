---
import type { SiteSocialIconKey } from '../../lib/theme-settings';
import { ADMIN_SOCIAL_DISPLAY_TEXT_MAX_LENGTH } from '../../lib/admin-console/theme-shared';
import BrandIcon from '../BrandIcon.astro';
import AdminIcon from './AdminIcon.astro';

interface SocialIconOption {
  value: SiteSocialIconKey;
  optionLabel: string;
  defaultLabel: string;
}

interface Props {
  socialIconOptions: readonly SocialIconOption[];
  customSocialIconOptions: readonly SocialIconOption[];
  defaultCustomSocialIconKey: SiteSocialIconKey;
}

const { socialIconOptions, customSocialIconOptions, defaultCustomSocialIconKey } = Astro.props;
---

<template id="site-social-custom-row-template">
  <article class="admin-row admin-row--interactive admin-row--table admin-social-row" data-social-custom-row>
    <div class="admin-field admin-social-field admin-social-field--order">
      <span class="admin-social-cell-label">上移</span>
      <button
        class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-social-action admin-social-action--move"
        type="button"
        data-social-custom-action="move-up"
        aria-label="链接上移"
        title="链接上移"
      >
        <AdminIcon name="arrow-up" class="admin-social-action__icon" size={15} />
        <span class="sr-only">链接上移</span>
      </button>
      <input data-social-custom-field="order" name="site-social-custom-order[]" type="hidden" />
    </div>

    <label class="admin-field admin-social-field admin-social-field--platform">
      <span class="admin-social-cell-label">平台</span>
      <select class="admin-field__control" data-social-custom-field="iconKey" name="site-social-custom-icon-key[]">
        {
          customSocialIconOptions.map((option) => (
            <option value={option.value} data-social-default-label={option.defaultLabel}>
              {option.optionLabel}
            </option>
          ))
        }
      </select>
    </label>

    <input data-social-custom-field="id" name="site-social-custom-id[]" type="hidden" />

    <div class="admin-social-field admin-social-field--icon">
      <span class="admin-social-cell-label">图标</span>
      <div class="admin-social-icon-preview" data-social-custom-icon-preview>
        {
          socialIconOptions.map((option) => (
            <span
              class="admin-social-icon-only"
              data-social-custom-icon-option={option.value}
              hidden={option.value !== defaultCustomSocialIconKey}
            >
              <BrandIcon name={option.value} class="admin-social-icon-only__icon" size={16} />
            </span>
          ))
        }
      </div>
    </div>

    <label class="admin-field admin-social-field admin-social-field--href">
      <span class="admin-social-cell-label">链接地址</span>
      <span class="admin-social-link-inline">
        <span class="admin-social-link-label" hidden>
          <input
            class="admin-field__control admin-social-link-label__input"
            data-social-custom-field="label"
            name="site-social-custom-label[]"
            type="text"
            autocomplete="off"
            spellcheck="false"
            placeholder="自定义名称"
          />
        </span>
        <input
          class="admin-field__control admin-field__control--soft admin-social-link-inline__href"
          data-social-custom-field="href"
          name="site-social-custom-href[]"
          type="url"
          inputmode="url"
          autocomplete="off"
          placeholder="https://example.com"
        />
      </span>
    </label>

    <label class="admin-field admin-social-field admin-social-field--display">
      <span class="admin-social-cell-label">详细显示</span>
      <input
        class="admin-field__control admin-field__control--soft"
        data-social-custom-field="displayText"
        name="site-social-custom-display-text[]"
        type="text"
        autocomplete="off"
        spellcheck="false"
        maxlength={String(ADMIN_SOCIAL_DISPLAY_TEXT_MAX_LENGTH)}
        placeholder="平台昵称"
      />
    </label>

    <div class="admin-social-field admin-social-field--actions">
      <span class="admin-social-cell-label">操作</span>
      <div class="admin-social-row-actions">
        <input
          data-social-custom-field="visible"
          name="site-social-custom-visible[]"
          type="checkbox"
          class="sr-only"
        />
        <button
          class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-social-action"
          type="button"
          data-social-custom-action="toggle-visible"
          aria-pressed="true"
        >
          <AdminIcon name="eye" class="admin-social-action__icon" size={15} />
          <span class="sr-only" data-social-custom-visible-label>隐藏链接</span>
        </button>
        <button
          class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-social-action admin-social-action--danger"
          type="button"
          data-social-custom-action="remove"
          aria-label="删除链接"
          title="删除链接"
        >
          <AdminIcon name="trash" class="admin-social-action__icon" size={15} />
          <span class="sr-only">删除链接</span>
        </button>
      </div>
    </div>
  </article>
</template>
