---
import UiIcon from './UiIcon.astro';
import SidebarAdminNav from './sidebar/SidebarAdminNav.astro';
import SidebarNavSwitcher from './sidebar/SidebarNavSwitcher.astro';
import SidebarPublicNav from './sidebar/SidebarPublicNav.astro';
import { ADMIN_ROUTES, isAdminRoutePathActive } from '../lib/admin-console/routes';
import { createWithBase } from '../utils/format';
import { getSidebarHref, getThemeSettings, type SidebarNavId } from '../lib/theme-settings';

const {
  siteTitle = 'Whono',
  activeNavId,
  isDev = false
} = Astro.props as {
  siteTitle?: string;
  activeNavId?: SidebarNavId;
  isDev?: boolean;
};

const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const homeHref = withBase('/');
const { settings } = getThemeSettings();
const quote = settings.shell.quote;
const nav = settings.shell.nav
  .filter((item) => item.visible)
  .sort((a, b) => a.order - b.order)
  .map((item) => {
    const href = withBase(getSidebarHref(item.id));
    return {
      id: item.id,
      label: item.label,
      ornament: item.ornament,
      href,
      isActive: activeNavId
        ? item.id === activeNavId
        : pathname === href || (href !== homeHref && pathname.startsWith(href))
    };
  });
const adminNav = ADMIN_ROUTES.map((route) => {
  const href = withBase(route.href);
  return {
    href,
    label: route.sidebarLabel,
    description: route.description,
    isActive: isAdminRoutePathActive(pathname, href, route.activeMatch)
  };
});
const showReaderToggle = settings.ui.readingMode.showEntry;
const showRssLink = settings.ui.sidebarActions.showRssLink;
const showThemeToggle = settings.ui.sidebarActions.showThemeToggle;
const showAdminEntry = settings.ui.sidebarActions.showAdminEntry && settings.site.adminOverview.publicVisible;
---

<aside class="sidebar">
  <a class="sidebar__title" href={homeHref} aria-label={`${siteTitle} 首页`}>{siteTitle}</a>

  <div class="sidebar__quote">
    {quote.split('\n').map((line) => (
      <>
        {line}<br />
      </>
    ))}
  </div>

  {isDev ? (
    <div class="sidebar-nav-panels" data-admin-sidebar-nav>
      <div class="sidebar-nav-stage" data-admin-nav-stage>
        <SidebarPublicNav items={nav} isAdminNavPanel />
        <SidebarAdminNav items={adminNav} />
      </div>
      <div class="sidebar-nav-switcher-item">
        <SidebarNavSwitcher />
      </div>
    </div>
  ) : (
    <SidebarPublicNav items={nav} />
  )}

  <div class="sidebar-actions">
    {showReaderToggle ? (
      <button
        id="reader-toggle"
        class="icon-button reader-toggle"
        type="button"
        aria-label="阅读模式"
        aria-pressed="false"
        title="阅读模式"
      >
        <UiIcon name="book-open" class="icon icon-book-open" />
        <UiIcon name="book-closed" class="icon icon-book-closed" />
      </button>
    ) : null}

    {showRssLink ? (
      <a class="icon-button rss-link" href={withBase('/archive/rss.xml')} aria-label="RSS 订阅" title="RSS 订阅">
        <UiIcon name="rss" class="icon" />
      </a>
    ) : null}

    {showThemeToggle ? (
      <button
        id="theme-toggle"
        class="icon-button theme-toggle"
        type="button"
        aria-label="夜间模式"
        aria-pressed="false"
        title="夜间模式"
      >
        <UiIcon name="sun-moon" class="icon icon-system" />
        <UiIcon name="moon" class="icon icon-moon" />
        <UiIcon name="sun" class="icon icon-sun" />
      </button>
    ) : null}

    {showAdminEntry ? (
      <a class="icon-button admin-entry-link" href={withBase('/admin/')} aria-label="站点概览" title="站点概览">
        <UiIcon name="monitor-dot" class="icon" />
      </a>
    ) : null}
  </div>
</aside>
