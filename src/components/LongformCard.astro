---
import { formatISODateUtc } from '../utils/format';
import type { ArticleMetaSettings } from '../lib/theme-settings';
import type { LongformArticlePeople } from '../lib/longform-people';

const {
  href,
  title,
  excerpt,
  date,
  visibleTags = [],
  badge = '长文',
  slug = '',
  articlePeople = { authors: [], translator: null },
  articleMetaSettings
} = Astro.props as {
  href: string;
  title: string;
  excerpt?: string | null;
  date: Date;
  visibleTags?: string[];
  badge?: string;
  slug?: string;
  articlePeople?: LongformArticlePeople;
  articleMetaSettings: ArticleMetaSettings;
};
const displayBadge = badge.trim() ? badge : '长文';
const shouldShowPeople = articlePeople.authors.length > 0 || Boolean(articlePeople.translator);
const shouldShowMetaLine =
  shouldShowPeople ||
  articleMetaSettings.showDate ||
  (articleMetaSettings.showTags && visibleTags.length > 0);
---

<a
  class="list-item list-item--link"
  href={href}
  data-entry-item
  data-slug={slug || undefined}
>
  <div class="list-item__row">
    <div style="display:flex; align-items:center; gap:10px; min-width:0;">
      <span class="badge">{displayBadge}</span>
      <h2 class="list-item__title" style="margin:0; min-width:0;">{title}</h2>
    </div>
  </div>
  {excerpt ? <p class="list-item__excerpt">{excerpt}</p> : null}
  {shouldShowMetaLine ? (
    <div class="meta-line meta-line--items">
      {shouldShowPeople ? (
        <span class="meta-line__item meta-line__item--people longform-card__people">
          {articlePeople.authors.length ? (
            <>
              <span class="article-byline__label">作者</span>
              <span class="article-author-list">
                {articlePeople.authors.map((author) => (
                  <span class="article-author">
                    {author.showAvatar ? (
                      <span class="article-author-avatar article-author-avatar--image" aria-hidden="true">
                        <img
                          src={author.avatar}
                          alt=""
                          width="32"
                          height="32"
                          loading="lazy"
                          decoding="async"
                          onerror="this.parentElement?.remove();"
                        />
                      </span>
                    ) : null}
                    <span class="article-byline__name">{author.name}</span>
                  </span>
                ))}
              </span>
            </>
          ) : null}
          {articlePeople.translator ? (
            <span class="article-translator">
              <span class="article-byline__label">翻译</span>
              <span class="article-author">
                {articlePeople.translator.showAvatar ? (
                  <span class="article-author-avatar article-author-avatar--image" aria-hidden="true">
                    <img
                      src={articlePeople.translator.avatar}
                      alt=""
                      width="32"
                      height="32"
                      loading="lazy"
                      decoding="async"
                      onerror="this.parentElement?.remove();"
                    />
                  </span>
                ) : null}
                <span class="article-byline__name">{articlePeople.translator.name}</span>
              </span>
            </span>
          ) : null}
        </span>
      ) : null}
      {articleMetaSettings.showDate ? (
        <span class="meta-line__item">
          {articleMetaSettings.dateLabel ? `${articleMetaSettings.dateLabel}` : ''}{formatISODateUtc(date)}
        </span>
      ) : null}
      {articleMetaSettings.showTags && visibleTags.length ? (
        <span class="meta-line__item meta-line__item--tags">
          {visibleTags.map((tag) => (<span class="tag">#{tag}</span>))}
        </span>
      ) : null}
    </div>
  ) : null}
</a>
